<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Custom Quote Training | Hearing Benefit Services</title>
  <style>
    /* ── RESET & BASE ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      background: #f0f4f8;
      color: #1a202c;
      line-height: 1.7;
    }

    /* ── LOGIN OVERLAY ── */
    #login-overlay {
      position: fixed; inset: 0;
      background: linear-gradient(135deg, #0a3d62 0%, #1e6fa8 100%);
      display: flex; align-items: center; justify-content: center;
      z-index: 9999;
    }
    .login-box {
      background: #fff;
      border-radius: 16px;
      padding: 48px 40px;
      width: min(420px, 92vw);
      box-shadow: 0 24px 64px rgba(0,0,0,.25);
      text-align: center;
    }
    .login-box img { width: 80px; margin-bottom: 16px; }
    .login-box h2 { font-size: 1.5rem; color: #0a3d62; margin-bottom: 6px; }
    .login-box p  { font-size: .9rem; color: #718096; margin-bottom: 28px; }
    .login-box input {
      width: 100%; padding: 12px 16px;
      border: 1.5px solid #cbd5e0; border-radius: 8px;
      font-size: 1rem; margin-bottom: 14px;
      transition: border-color .2s;
    }
    .login-box input:focus { outline: none; border-color: #1e6fa8; }
    .login-box button {
      width: 100%; padding: 13px;
      background: linear-gradient(135deg, #0a3d62, #1e6fa8);
      color: #fff; border: none; border-radius: 8px;
      font-size: 1rem; font-weight: 600; cursor: pointer;
      transition: opacity .2s;
    }
    .login-box button:hover { opacity: .88; }
    #login-error {
      color: #e53e3e; font-size: .85rem;
      margin-top: 10px; display: none;
    }

    /* ── MAIN CONTENT (hidden until login) ── */
    #main-content { display: none; }

    /* ── TOP HEADER ── */
    header {
      background: linear-gradient(135deg, #0a3d62 0%, #1e6fa8 100%);
      color: #fff; padding: 48px 24px; text-align: center;
    }
    header h1 { font-size: clamp(1.6rem, 4vw, 2.6rem); font-weight: 700; }
    header p  { margin-top: 10px; font-size: 1.05rem; opacity: .88; }

    /* ── STICKY NAV ── */
    nav.sticky {
      position: sticky; top: 0; z-index: 100;
      background: #0a3d62; padding: 0 16px;
      overflow-x: auto; white-space: nowrap;
      box-shadow: 0 2px 8px rgba(0,0,0,.3);
    }
    nav.sticky a {
      display: inline-block; color: #bee3f8;
      text-decoration: none; padding: 14px 18px;
      font-size: .88rem; font-weight: 500;
      transition: color .2s, background .2s;
    }
    nav.sticky a:hover { color: #fff; background: rgba(255,255,255,.1); }

    /* ── LAYOUT ── */
    .container { max-width: 960px; margin: 0 auto; padding: 40px 20px 80px; }

    /* ── SECTION CARDS ── */
    section {
      background: #fff;
      border-radius: 14px;
      padding: 36px 32px;
      margin-bottom: 32px;
      box-shadow: 0 2px 12px rgba(0,0,0,.07);
    }
    section h2 {
      font-size: 1.35rem; font-weight: 700;
      color: #0a3d62; margin-bottom: 16px;
      padding-bottom: 10px;
      border-bottom: 2px solid #bee3f8;
    }
    section h3 {
      font-size: 1.05rem; font-weight: 700;
      color: #1e6fa8; margin: 22px 0 8px;
    }
    section p  { margin-bottom: 12px; color: #2d3748; }
    section ul, section ol {
      padding-left: 20px; margin-bottom: 12px;
    }
    section li { margin-bottom: 6px; color: #2d3748; }

    /* ── PROGRESS TIMELINE ── */
    .timeline { position: relative; padding-left: 32px; margin-top: 8px; }
    .timeline::before {
      content: ''; position: absolute; left: 10px; top: 0; bottom: 0;
      width: 3px; background: #bee3f8; border-radius: 2px;
    }
    .timeline-item { position: relative; margin-bottom: 24px; }
    .timeline-item::before {
      content: '';
      position: absolute; left: -26px; top: 4px;
      width: 14px; height: 14px;
      border-radius: 50%;
      background: #1e6fa8;
      border: 3px solid #fff;
      box-shadow: 0 0 0 2px #1e6fa8;
    }
    .timeline-item strong { color: #0a3d62; display: block; margin-bottom: 2px; }

    /* ── STEP BADGES ── */
    .step-badge {
      display: inline-block;
      background: #ebf8ff;
      color: #1e6fa8;
      border: 1px solid #bee3f8;
      border-radius: 20px;
      font-size: .78rem; font-weight: 700;
      padding: 2px 10px;
      margin-right: 6px;
    }

    /* ── STATUS CHIPS ── */
    .chip {
      display: inline-block;
      padding: 3px 12px;
      border-radius: 12px;
      font-size: .78rem; font-weight: 700;
      margin: 2px;
    }
    .chip-blue   { background: #ebf8ff; color: #1e6fa8; }
    .chip-green  { background: #f0fff4; color: #276749; }
    .chip-yellow { background: #fffff0; color: #744210; }
    .chip-red    { background: #fff5f5; color: #c53030; }
    .chip-purple { background: #faf5ff; color: #553c9a; }

    /* ── INFO / WARNING BOXES ── */
    .info-box, .warn-box, .success-box {
      border-radius: 10px;
      padding: 16px 20px;
      margin: 16px 0;
      font-size: .93rem;
    }
    .info-box    { background: #ebf8ff; border-left: 4px solid #1e6fa8; color: #1a365d; }
    .warn-box    { background: #fffbeb; border-left: 4px solid #d69e2e; color: #744210; }
    .success-box { background: #f0fff4; border-left: 4px solid #38a169; color: #22543d; }

    /* ── ACTION TABLE ── */
    .action-table { width: 100%; border-collapse: collapse; margin-top: 12px; font-size: .92rem; }
    .action-table th {
      background: #0a3d62; color: #fff;
      padding: 10px 14px; text-align: left;
    }
    .action-table td { padding: 10px 14px; border-bottom: 1px solid #e2e8f0; }
    .action-table tr:nth-child(even) td { background: #f7fafc; }

    /* ── CHECKLIST ── */
    .checklist { list-style: none; padding: 0; }
    .checklist li {
      padding: 8px 0 8px 32px;
      position: relative;
      border-bottom: 1px solid #f0f4f8;
      color: #2d3748;
    }
    .checklist li::before {
      content: '☐';
      position: absolute; left: 0;
      font-size: 1.1rem; color: #1e6fa8;
    }

    /* ── FOOTER ── */
    footer {
      text-align: center; padding: 32px 16px;
      font-size: .82rem; color: #718096;
    }
    footer a { color: #1e6fa8; text-decoration: none; }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      section { padding: 24px 18px; }
      .login-box { padding: 36px 24px; }
    }
  </style>
</head>
