════════════════════════════════════════ -->
<div id="main-content">

  <header>
    <h1>🎧 Custom Quote Lead Lifecycle — Staff Training Guide</h1>
    <p>Everything Seteisha needs to know about the Custom Quote workflow from start to finish.</p>
  </header>

  <nav class="sticky">
    <a href="#overview">Overview</a>
    <a href="#triggers">How It Starts</a>
    <a href="#tagging">Auto-Tagging</a>
    <a href="#notifications">Your Notifications</a>
