<script>
  const revealObserver = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        revealObserver.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

  document.querySelectorAll('.faq-q-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item   = btn.closest('.faq-item');
      const ans    = item.querySelector('.faq-ans');
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item.open').forEach(i => {
        i.classList.remove('open');
        i.querySelector('.faq-ans').classList.remove('open');
        i.querySelector('.faq-q-btn').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('open');
        ans.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
    btn.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); btn.click(); }
    });
  });

  Chart.defaults.font.family = "'Poppins', sans-serif";
  Chart.defaults.font.size   = 14;
  Chart.defaults.color       = '#475569';

  const tooltipConfig = {
    backgroundColor: '#1B4965',
    titleFont:  { size: 15, weight: 'bold' },
    bodyFont:   { size: 13 },
    padding:    16,
    cornerRadius: 12,
    callbacks: {
      title: function(items) {
        const label = items[0].chart.data.labels[items[0].dataIndex];
        return Array.isArray(label) ? label.join(' ') : label;
      }
    }
  };

  function wrapLabel(str, maxLen = 16) {
    if (!str || str.length <= maxLen) return str;
    const words = str.split(' ');
    const lines = [];
    let line = words[0];
    for (let i = 1; i < words.length; i++) {
      if (line.length + 1 + words[i].length <= maxLen) { line += ' ' + words[i]; }
      else { lines.push(line); line = words[i]; }
    }
    lines.push(line);
    return lines;
  }

  window.addEventListener('load', () => {

    const rCtx = document.getElementById('impactRadar');
    if (rCtx) {
      new Chart(rCtx, {
        type: 'radar',
        data: {
          labels: [
            wrapLabel('Sleep Disruption'),
            wrapLabel('Quiet Moments'),
            wrapLabel('Concentration'),
            wrapLabel('Anxiety Levels'),
            wrapLabel('Social Life'),
            wrapLabel('Emotional Wellbeing')
          ],
          datasets: [{
            label: 'Severity Impact',
            data: [9.2, 10, 8.5, 7.8, 7.2, 6.5],
            fill: true,
            backgroundColor: 'rgba(6,182,212,0.18)',
            borderColor: '#06B6D4',
            borderWidth: 3,
            pointBackgroundColor: '#1B4965',
            pointRadius: 5
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            r: {
              suggestedMin: 0,
              suggestedMax: 10,
              ticks: { display: false },
              grid: { color: 'rgba(27,73,101,0.12)' },
              pointLabels: { font: { weight: '700', size: 12 }, color: '#1B4965' }
            }
          },
          plugins: {
            tooltip: tooltipConfig,
            legend: { display: false }
          }
        }
      });
    }

    const bCtx = document.getElementById('outcomeBarChart');
    if (bCtx) {
      new Chart(bCtx, {
        type: 'bar',
        data: {
          labels: [
            wrapLabel('Untreated'),
            wrapLabel('Traditional Masking'),
            wrapLabel('Signia Notch Therapy')
          ],
          datasets: [{
            label: 'Clinical Satisfaction Rate (%)',
            data: [12, 42, 89],
            backgroundColor: ['#e2e8f0', '#2A64A7', '#1B4965'],
            borderRadius: 12,
            barThickness: 52
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            x: {
              max: 100,
              ticks: { font: { weight: '700' }, callback: v => v + '%' },
              grid: { color: 'rgba(0,0,0,0.05)' }
            },
            y: {
              ticks: { font: { weight: '700' }, color: '#1B4965' },
              grid: { display: false }
            }
          },
          plugins: {
            tooltip: tooltipConfig,
            legend: { display: false }
          }
        }
      });
    }
  });
</script>

