<script>
  /* ── Dropdown IDs ─────────────────────────────────────────── */
  const DD_IDS = ['tech', 'hearing', 'resources', 'support'];
  const closeTimers = {};

  /* ── Open panel ──────────────────────────────────────────── */
  function openPanel(name) {
    cancelClose(name);
    DD_IDS.forEach(id => { if (id !== name) closePanelNow(id); });
    const p = document.getElementById('panel-' + name);
    if (p) {
      p.style.display = 'flex';
      requestAnimationFrame(() => p.classList.add('is-open'));
    }
    const wrapper = document.querySelector('[data-dd="' + name + '"]');
    if (wrapper) {
      const btn  = wrapper.querySelector('.nav-link');
      const chev = wrapper.querySelector('.dd-chevron');
      if (btn)  btn.classList.add('is-active');
      if (chev) chev.style.transform = 'rotate(180deg)';
    }
  }

  /* ── Schedule close with delay ───────────────────────────── */
  function scheduleClose(name) {
    closeTimers[name] = setTimeout(() => closePanelNow(name), 180);
  }

  /* ── Cancel a pending close ──────────────────────────────── */
  function cancelClose(name) { clearTimeout(closeTimers[name]); }

  /* ── Immediately close panel ─────────────────────────────── */
  function closePanelNow(name) {
    const p = document.getElementById('panel-' + name);
    if (p) {
      p.classList.remove('is-open');
      setTimeout(() => { if (!p.classList.contains('is-open')) p.style.display = 'none'; }, 200);
    }
    const wrapper = document.querySelector('[data-dd="' + name + '"]');
    if (wrapper) {
      const btn  = wrapper.querySelector('.nav-link');
      const chev = wrapper.querySelector('.dd-chevron');
      if (btn)  btn.classList.remove('is-active');
      if (chev) chev.style.transform = 'rotate(0deg)';
    }
  }

  /* ── Attach hover listeners ──────────────────────────────── */
  document.querySelectorAll('.dd-wrapper').forEach(wrapper => {
    const name = wrapper.dataset.dd;
    wrapper.addEventListener('mouseenter', () => openPanel(name));
    wrapper.addEventListener('mouseleave', () => scheduleClose(name));
  });

  /* ── Close on outside click ──────────────────────────────── */
  document.addEventListener('click', e => {
    const inWrapper = e.target.closest('.dd-wrapper');
    const inPanel   = e.target.closest('.mega-panel');
    if (!inWrapper && !inPanel) DD_IDS.forEach(closePanelNow);
  });

  /* ── Mobile accordion ────────────────────────────────────── */
  function toggleMob(id) {
    const panel = document.getElementById(id);
    const icon  = document.getElementById('icon-' + id);
    if (!panel) return;
    const isOpen = panel.classList.contains('open');
    panel.classList.toggle('open', !isOpen);
    if (icon) icon.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
  }

  /* ── Hamburger ───────────────────────────────────────────── */
  const hamburger  = document.getElementById('hbs-hamburger-btn');
  const mobileMenu = document.getElementById('hbs-mobile-menu');
  const hamIcon    = document.getElementById('hbs-ham-icon');
  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.contains('open');
      mobileMenu.classList.toggle('open', !isOpen);
      hamIcon.className = isOpen ? 'fa-solid fa-bars' : 'fa-solid fa-xmark';
    });
  }

  /* ── GHL full-width parent overrides ─────────────────────── */
  document.querySelectorAll(
    '.c-column:has(.hbs-nav-wrapper), .c-row:has(.hbs-nav-wrapper), .c-section:has(.hbs-nav-wrapper)'
  ).forEach(el => {
    el.style.maxWidth      = '100%';
    el.style.width         = '100%';
    el.style.paddingLeft   = '0';
    el.style.paddingRight  = '0';
    el.style.paddingTop    = '0';
    el.style.paddingBottom = '0';
    el.style.marginLeft    = '0';
    el.style.marginRight   = '0';
    el.style.marginTop     = '0';
    el.style.marginBottom  = '0';
  });

  /* ── Nuclear gap removal ─────────────────────────────────── */
  (function removeTopGap() {
    function zeroGaps() {
      document.querySelectorAll('.c-section, .c-row, .c-column, .c-wrapper')
        .forEach(el => { el.style.marginBottom = '0'; el.style.paddingBottom = '0'; });

      let el = document.querySelector('.hbs-nav-wrapper');
      while (el && el !== document.body) {
        el.style.marginBottom  = '0';
        el.style.paddingBottom = '0';
        el = el.parentElement;
      }

      const allSections = Array.from(document.querySelectorAll('.c-section'));
      const navSection  = allSections.find(s => s.contains(document.querySelector('.hbs-nav-wrapper')));
      if (navSection) {
        navSection.style.marginBottom  = '0';
        navSection.style.paddingBottom = '0';
        let next = navSection.nextElementSibling;
        while (next) {
          next.style.marginTop  = '0';
          next.style.paddingTop = '0';
          if (next.offsetHeight > 0) break;
          next = next.nextElementSibling;
        }
      }

      document.querySelectorAll('body > div, body > section, body > main')
        .forEach(el => { el.style.marginTop = '0'; });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', zeroGaps);
    } else { zeroGaps(); }
    [100, 300, 600, 1000, 2000].forEach(t => setTimeout(zeroGaps, t));
  })();
</script>

