<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HBS Navigation</title>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&family=Poppins:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
  />
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    /* ── BRAND TOKENS ─────────────────────────────────────────── */
    :root {
      --navy:        #0a1628;
      --navy-light:  #1a2b4a;
      --navy-mid:    #162240;
      --gold:        #b8972a;
      --gold-light:  #d4af37;
      --white:       #ffffff;
      --off-white:   #f8f7f4;
      --text-dark:   #1a2b4a;
      --text-muted:  #6b7280;
      --border:      #e5e7eb;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Poppins', sans-serif;
      margin: 0 !important;
      padding: 0 !important;
    }

    /* ── NUCLEAR SPACING RESET ────────────────────────────────── */
    .hbs-nav-wrapper,
    .c-column:has(.hbs-nav-wrapper),
    .c-row:has(.hbs-nav-wrapper),
    .c-section:has(.hbs-nav-wrapper) {
      margin:  0 !important;
      padding: 0 !important;
    }

    /* ── NAV WRAPPER ──────────────────────────────────────────── */
    .hbs-nav-wrapper {
      position: relative;
      width: 100vw;
      left: 50%;
      transform: translateX(-50%);
      background: var(--navy);
      border-top: 1px solid rgba(255,255,255,0.08);
      z-index: 9998;
      margin: 0 !important;
      padding: 0 !important;
    }

    /* ── GHL PARENT FULL-WIDTH OVERRIDE ──────────────────────── */
    .c-column:has(.hbs-nav-wrapper),
    .c-row:has(.hbs-nav-wrapper),
    .c-section:has(.hbs-nav-wrapper) {
      width:         100% !important;
      max-width:     100% !important;
      padding-left:  0 !important;
      padding-right: 0 !important;
      padding-top:   0 !important;
      margin-left:   0 !important;
      margin-right:  0 !important;
      margin-top:    0 !important;
    }

    /* ── NAV INNER GRID ───────────────────────────────────────── */
    .hbs-nav-inner {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      width: 100%;
      padding: 0 32px 0 20px;
      min-height: 72px;
      position: relative;
    }

    /* ── LOGO ─────────────────────────────────────────────────── */
    .hbs-nav-logo { justify-self: start; }
    .hbs-nav-logo img {
      width: 170px;
      height: auto;
      display: block;
      filter: brightness(0) invert(1);
    }

    /* ── DESKTOP NAV LINKS ────────────────────────────────────── */
    .hbs-nav-links {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2px;
      flex-wrap: nowrap;
    }

    .nav-link {
      font-family: 'Poppins', sans-serif;
      font-size: 19px;                         /* was 17px → +2pt */
      font-weight: 500;
      color: rgba(255,255,255,0.88);
      padding: 8px 12px;
      border-radius: 6px;
      background: none;
      border: none;
      cursor: pointer;
      white-space: nowrap;
      letter-spacing: 0.01em;
      text-decoration: none;
      position: relative;
      transition: color 0.2s;
    }

    /* Gold underline on hover / active */
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: 2px;
      left: 12px;
      right: 12px;
      height: 2px;
      background: var(--gold-light);
      transform: scaleX(0);
      transform-origin: center;
      transition: transform 0.2s ease;
      border-radius: 2px;
    }
    .nav-link:hover,
    .nav-link.is-active { color: var(--gold-light); }
    .nav-link:hover::after,
    .nav-link.is-active::after { transform: scaleX(1); }

    /* ── RIGHT SIDE ───────────────────────────────────────────── */
    .hbs-nav-right {
      display: flex;
      align-items: center;
      gap: 10px;
      justify-self: end;
    }

    .hbs-cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      border-radius: 8px;
      font-family: 'Poppins', sans-serif;
      font-size: 19px;                         /* was 17px → +2pt */
      font-weight: 600;
      color: var(--navy);
      background: var(--gold);
      text-decoration: none;
      white-space: nowrap;
      border: 2px solid transparent;
      transition: background 0.2s, transform 0.15s;
      letter-spacing: 0.01em;
    }
    .hbs-cta-btn:hover {
      background: var(--gold-light);
      transform: translateY(-1px);
    }

    /* ── HAMBURGER ────────────────────────────────────────────── */
    .hbs-hamburger {
      display: none;
      align-items: center;
      justify-content: center;
      width: 42px;
      height: 42px;
      border-radius: 8px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      color: var(--white);
      font-size: 18px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .hbs-hamburger:hover { background: rgba(255,255,255,0.14); }

    /* ── FULL-WIDTH MEGA PANELS ───────────────────────────────── */
    .mega-panel {
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%) translateY(-6px);
      width: 100vw;
      background: var(--white);
      border-top: 3px solid var(--gold);
      box-shadow: 0 12px 48px rgba(10,22,40,0.18);
      z-index: 9997;
      display: none;
      opacity: 0;
      transition: opacity 0.2s ease, transform 0.2s ease;
      pointer-events: none;
    }
    .mega-panel.is-open {
      display: flex;
      opacity: 1;
      transform: translateX(-50%) translateY(0);
      pointer-events: all;
    }

    /* Left navy panel */
    .mega-left {
      width: 30%;
      min-width: 260px;
      background: var(--navy);
      padding: 40px 36px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 16px;
    }
    .mega-left-icon {
      width: 52px;
      height: 52px;
      border-radius: 12px;
      background: rgba(184,151,42,0.18);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--gold-light);
      font-size: 22px;
      margin-bottom: 4px;
    }
    .mega-left-title {
      font-family: 'Lora', serif;
      font-size: 24px;                         /* was 22px → +2pt */
      font-weight: 700;
      color: var(--white);
      line-height: 1.3;
    }
    .mega-left-desc {
      font-family: 'Poppins', sans-serif;
      font-size: 17px;                         /* was 15px → +2pt */
      font-weight: 400;
      color: rgba(255,255,255,0.70);
      line-height: 1.6;
    }
    .mega-left-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 8px;
      padding: 10px 20px;
      border-radius: 8px;
      background: var(--gold);
      color: var(--navy);
      font-family: 'Poppins', sans-serif;
      font-size: 17px;                         /* was 15px → +2pt */
      font-weight: 600;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
      align-self: flex-start;
    }
    .mega-left-cta:hover { background: var(--gold-light); transform: translateY(-1px); }

    /* Right white panel */
    .mega-right {
      flex: 1;
      padding: 36px 48px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      background: var(--white);
    }
    .mega-right-grid {
      display: grid;
      gap: 6px 32px;
    }
    .mega-right-grid.cols-1 { grid-template-columns: 1fr; }
    .mega-right-grid.cols-2 { grid-template-columns: 1fr 1fr; }

    .mega-section-label {
      font-family: 'Poppins', sans-serif;
      font-size: 14px;                         /* was 12px → +2pt */
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gold);
      padding: 0 0 6px 0;
      margin-bottom: 2px;
      border-bottom: 1px solid var(--border);
      grid-column: 1 / -1;
    }

    .mega-link {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 10px 12px;
      border-radius: 8px;
      text-decoration: none;
      transition: background 0.18s;
    }
    .mega-link:hover { background: var(--off-white); }
    .mega-link-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: #f0f4ff;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--navy-light);
      font-size: 14px;
      flex-shrink: 0;
      transition: background 0.18s, color 0.18s;
    }
    .mega-link:hover .mega-link-icon { background: var(--gold); color: var(--white); }
    .mega-link-text { display: flex; flex-direction: column; gap: 2px; }
    .mega-link-label {
      font-family: 'Poppins', sans-serif;
      font-size: 19px;                         /* was 17px → +2pt */
      font-weight: 500;
      color: var(--navy-light);
      line-height: 1.3;
    }
    .mega-link:hover .mega-link-label { color: var(--gold); }
    .mega-link-sub {
      font-family: 'Poppins', sans-serif;
      font-size: 15px;                         /* was 13px → +2pt */
      font-weight: 400;
      color: var(--text-muted);
      line-height: 1.4;
    }

    /* ── MOBILE MENU ──────────────────────────────────────────── */
    .hbs-mobile-menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      background: var(--navy);
      border-top: 1px solid rgba(255,255,255,0.1);
      box-shadow: 0 24px 48px rgba(0,0,0,0.35);
      z-index: 9999;
      max-height: 82vh;
      overflow-y: auto;
      padding: 12px 0 24px;
    }
    .hbs-mobile-menu.open { display: block; }

    .mobile-accordion-btn {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 13px 20px;
      font-family: 'Poppins', sans-serif;
      font-size: 20px;                         /* was 18px → +2pt */
      font-weight: 500;
      color: rgba(255,255,255,0.88);
      background: none;
      border: none;
      cursor: pointer;
      text-align: left;
      transition: background 0.2s, color 0.2s;
    }
    .mobile-accordion-btn:hover { background: rgba(184,151,42,0.12); color: var(--gold-light); }

    .mobile-accordion-panel { display: none; padding: 4px 0 8px 16px; }
    .mobile-accordion-panel.open { display: block; }

    .mobile-section-label {
      font-family: 'Poppins', sans-serif;
      font-size: 14px;                         /* was 12px → +2pt */
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gold);
      padding: 12px 14px 4px;
    }

    .mobile-sub-link {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      font-family: 'Poppins', sans-serif;
      font-size: 20px;                         /* was 18px → +2pt */
      font-weight: 400;
      color: rgba(255,255,255,0.80);
      text-decoration: none;
      border-radius: 8px;
      transition: background 0.2s, color 0.2s;
    }
    .mobile-sub-link:hover { background: rgba(184,151,42,0.12); color: var(--gold-light); }

    .mobile-direct-link {
      display: block;
      padding: 13px 20px;
      font-family: 'Poppins', sans-serif;
      font-size: 20px;                         /* was 18px → +2pt */
      font-weight: 500;
      color: rgba(255,255,255,0.88);
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
    }
    .mobile-direct-link:hover { background: rgba(184,151,42,0.12); color: var(--gold-light); }

    .mobile-cta-wrap {
      padding: 16px 20px 8px;
      border-top: 1px solid rgba(255,255,255,0.1);
      margin-top: 8px;
    }
    .mobile-cta-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      padding: 13px 20px;
      border-radius: 8px;
      background: var(--gold);
      color: var(--navy);
      font-family: 'Poppins', sans-serif;
      font-size: 20px;                         /* was 18px → +2pt */
      font-weight: 600;
      text-decoration: none;
      transition: background 0.2s;
    }
    .mobile-cta-btn:hover { background: var(--gold-light); }

    /* ── RESPONSIVE ───────────────────────────────────────────── */
    @media (max-width: 1023px) {
      .hbs-nav-inner {
        grid-template-columns: 1fr auto;
        padding: 0 16px;
        min-height: 64px;
      }
      .hbs-nav-links { display: none; }
      .hbs-cta-btn   { display: none; }
      .hbs-hamburger { display: flex; }
      .mega-panel    { display: none !important; }
    }
  </style>
</head>
