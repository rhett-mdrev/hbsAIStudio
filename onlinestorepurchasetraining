<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Online Store Pipeline | Hearing Benefit Services</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Poppins', sans-serif;
      background: #f0f4f8;
      color: #1a202c;
      line-height: 1.7;
    }

    /* ── LOGIN OVERLAY ── */
    #login-overlay {
      position: fixed; inset: 0;
      background: linear-gradient(135deg, #0a1628 0%, #1a3a5c 100%);
      display: flex; align-items: center; justify-content: center;
      z-index: 9999;
    }
    .login-box {
      background: #fff;
      border-radius: 16px;
      padding: 48px 40px;
      width: min(420px, 92vw);
      box-shadow: 0 24px 64px rgba(0,0,0,.35);
      text-align: center;
    }
    .login-logo {
      font-family: 'Lora', serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: #0a1628;
      margin-bottom: 6px;
      letter-spacing: 0.02em;
    }
    .login-box h2 {
      font-family: 'Lora', serif;
      font-size: 1.5rem;
      color: #0a1628;
      margin-bottom: 6px;
    }
    .login-box p { font-size: .9rem; color: #718096; margin-bottom: 28px; }
    .login-divider {
      width: 48px; height: 3px;
      background: linear-gradient(90deg, #b8972a, #d4af37);
      border-radius: 2px;
      margin: 0 auto 24px;
    }
    .login-box input {
      width: 100%; padding: 12px 16px;
      border: 1.5px solid #cbd5e0; border-radius: 8px;
      font-family: 'Poppins', sans-serif;
      font-size: 1rem; margin-bottom: 14px;
      transition: border-color .2s;
    }
    .login-box input:focus { outline: none; border-color: #b8972a; }
    .login-box button {
      width: 100%; padding: 13px;
      background: linear-gradient(135deg, #0a1628, #1a3a5c);
      color: #fff; border: none; border-radius: 8px;
      font-family: 'Poppins', sans-serif;
      font-size: 1rem; font-weight: 600; cursor: pointer;
      transition: opacity .2s;
      letter-spacing: 0.02em;
    }
    .login-box button:hover { opacity: .88; }
    #login-error {
      color: #e53e3e; font-size: .85rem;
      margin-top: 10px; display: none;
    }

    /* ── MAIN CONTENT ── */
    #main-content { display: none; }

    /* ── HEADER ── */
    header {
      background: linear-gradient(135deg, #0a1628 0%, #1a3a5c 100%);
      color: #fff;
      padding: 56px 24px 48px;
      text-align: center;
      border-bottom: 4px solid #b8972a;
    }
    header .eyebrow {
      font-size: .8rem; font-weight: 600;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: #b8972a; margin-bottom: 12px;
    }
    header h1 {
      font-family: 'Lora', serif;
      font-size: clamp(1.6rem, 4vw, 2.6rem);
      font-weight: 700; margin-bottom: 12px;
    }
    header p { font-size: 1rem; opacity: .82; max-width: 600px; margin: 0 auto; }

    /* ── STICKY NAV ── */
    nav.sticky {
      position: sticky; top: 0; z-index: 100;
      background: #0a1628;
      padding: 0 16px;
      overflow-x: auto; white-space: nowrap;
      box-shadow: 0 2px 12px rgba(0,0,0,.3);
      border-bottom: 2px solid #b8972a;
    }
    nav.sticky a {
      display: inline-block; color: rgba(255,255,255,.72);
      text-decoration: none; padding: 14px 16px;
      font-size: .82rem; font-weight: 500;
      letter-spacing: 0.03em;
      transition: color .2s, background .2s;
    }
    nav.sticky a:hover { color: #d4af37; background: rgba(255,255,255,.06); }

    /* ── LAYOUT ── */
    .container { max-width: 980px; margin: 0 auto; padding: 40px 20px 80px; }

    /* ── SECTION CARDS ── */
    section {
      background: #fff;
      border-radius: 14px;
      padding: 36px 32px;
      margin-bottom: 28px;
      box-shadow: 0 2px 12px rgba(0,0,0,.07);
    }
    section h2 {
      font-family: 'Lora', serif;
      font-size: 1.3rem; font-weight: 700;
      color: #0a1628; margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 2px solid #b8972a;
      display: flex; align-items: center; gap: 10px;
    }
    section h3 {
      font-size: 1rem; font-weight: 600;
      color: #1a3a5c; margin: 22px 0 8px;
    }
    section p { margin-bottom: 12px; color: #2d3748; font-size: .95rem; }
    section ul, section ol { padding-left: 20px; margin-bottom: 12px; }
    section li { margin-bottom: 6px; color: #2d3748; font-size: .93rem; }

    /* ── INFO BOXES ── */
    .info-box, .warn-box, .success-box, .purple-box {
      border-radius: 10px; padding: 16px 20px;
      margin: 16px 0; font-size: .92rem;
    }
    .info-box    { background: #eff6ff; border-left: 4px solid #2563eb; color: #1e3a5f; }
    .warn-box    { background: #fff7ed; border-left: 4px solid #d97706; color: #92400e; }
    .success-box { background: #f0fdf4; border-left: 4px solid #16a34a; color: #14532d; }
    .purple-box  { background: #faf5ff; border-left: 4px solid #7c3aed; color: #3b0764; }
    .gold-box    { background: #fefce8; border-left: 4px solid #b8972a; color: #713f12; }

    /* ── CHIPS ── */
    .chip {
      display: inline-block; padding: 3px 12px;
      border-radius: 20px; font-size: .75rem; font-weight: 600;
      margin: 2px; white-space: nowrap;
    }
    .chip-navy   { background: #e8f0fb; color: #0a1628; border: 1px solid #b8c9e8; }
    .chip-teal   { background: #e1f5ee; color: #085041; border: 1px solid #9fe1cb; }
    .chip-blue   { background: #eff6ff; color: #1e3a5f; border: 1px solid #b5d4f4; }
    .chip-amber  { background: #faeeda; color: #854f0b; border: 1px solid #fac775; }
    .chip-purple { background: #faf5ff; color: #3b0764; border: 1px solid #d8b4fe; }
    .chip-gray   { background: #f1efe8; color: #444441; border: 1px solid #d3d1c7; }
    .chip-green  { background: #f0fdf4; color: #14532d; border: 1px solid #bbf7d0; }
    .chip-red    { background: #fef2f2; color: #7f1d1d; border: 1px solid #fecaca; }

    /* ── TAG PILL ── */
    .tag {
      display: inline-block;
      background: #0a1628; color: #d4af37;
      border-radius: 4px; padding: 1px 8px;
      font-size: .73rem; font-weight: 600;
      font-family: 'Poppins', monospace;
      margin: 2px; letter-spacing: 0.03em;
    }
    .tag-remove {
      background: #fef2f2; color: #991b1b;
      border: 1px dashed #fca5a5;
    }
    .tag-add {
      background: #16a34a; color: #fff;
      border: none;
    }
    .tag-manual {
      background: #b8972a; color: #fff;
      border: none;
    }

    /* ── PIPELINE TABLE ── */
    .pipeline-table { width: 100%; border-collapse: collapse; margin-top: 12px; font-size: .88rem; }
    .pipeline-table th {
      background: #0a1628; color: #fff;
      padding: 12px 14px; text-align: left;
      font-weight: 600; letter-spacing: 0.03em;
    }
    .pipeline-table th:first-child { border-radius: 8px 0 0 0; }
    .pipeline-table th:last-child  { border-radius: 0 8px 0 0; }
    .pipeline-table td {
      padding: 12px 14px;
      border-bottom: 1px solid #e2e8f0;
      vertical-align: top;
      color: #2d3748;
    }
    .pipeline-table tr:nth-child(even) td { background: #f8faff; }
    .pipeline-table tr.wade-row td { background: #faf5ff; }
    .pipeline-table tr.wade-row td:first-child { border-left: 3px solid #7c3aed; }
    .stage-num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 28px; height: 28px;
      background: #0a1628; color: #d4af37;
      border-radius: 50%; font-weight: 700; font-size: .82rem;
      flex-shrink: 0;
    }
    .stage-num-purple {
      background: #7c3aed; color: #fff;
    }
    .owner-badge {
      display: inline-block; padding: 3px 10px;
      border-radius: 20px; font-size: .75rem; font-weight: 600;
      white-space: nowrap;
    }
    .owner-auto    { background: #e1f5ee; color: #085041; }
    .owner-set     { background: #eff6ff; color: #1e3a5f; }
    .owner-andrea  { background: #faeeda; color: #854f0b; }
    .owner-wade    { background: #faf5ff; color: #3b0764; }
    .owner-cust    { background: #f1efe8; color: #444441; }

    /* ── TIMELINE ── */
    .timeline { position: relative; padding-left: 36px; margin-top: 8px; }
    .timeline::before {
      content: ''; position: absolute; left: 12px; top: 4px; bottom: 4px;
      width: 3px; background: linear-gradient(180deg, #b8972a, #d4af37);
      border-radius: 2px;
    }
    .timeline-item { position: relative; margin-bottom: 20px; }
    .timeline-item::before {
      content: ''; position: absolute; left: -28px; top: 5px;
      width: 14px; height: 14px; border-radius: 50%;
      background: #b8972a; border: 3px solid #fff;
      box-shadow: 0 0 0 2px #b8972a;
    }
    .timeline-item .day {
      font-size: .75rem; font-weight: 700; color: #b8972a;
      text-transform: uppercase; letter-spacing: 0.08em;
      margin-bottom: 2px;
    }
    .timeline-item strong { color: #0a1628; display: block; margin-bottom: 2px; font-size: .95rem; }
    .timeline-item p { font-size: .88rem; color: #4a5568; margin: 0; }

    /* ── CHECKLIST ── */
    .checklist { list-style: none; padding: 0; }
    .checklist li {
      padding: 10px 0 10px 36px;
      position: relative;
      border-bottom: 1px solid #f0f4f8;
      color: #2d3748; font-size: .93rem;
    }
    .checklist li::before {
      content: '☐'; position: absolute; left: 0;
      font-size: 1.15rem; color: #b8972a;
    }

    /* ── LEGEND ── */
    .legend {
      display: flex; flex-wrap: wrap; gap: 10px;
      margin-bottom: 20px; padding: 16px 20px;
      background: #f8faff; border-radius: 10px;
      border: 1px solid #e2e8f0;
    }
    .legend-item {
      display: flex; align-items: center; gap: 6px;
      font-size: .82rem; font-weight: 500; color: #4a5568;
    }
    .legend-dot {
      width: 12px; height: 12px; border-radius: 3px; flex-shrink: 0;
    }

    /* ── FOOTER ── */
    footer {
      text-align: center; padding: 32px 16px;
      font-size: .82rem; color: #718096;
      border-top: 1px solid #e2e8f0;
      background: #fff;
    }

    @media (max-width: 640px) {
      section { padding: 24px 18px; }
      .login-box { padding: 36px 24px; }
      .pipeline-table { font-size: .8rem; }
      .pipeline-table td, .pipeline-table th { padding: 10px 10px; }
    }
  </style>
</head>
<body>

<!-- LOGIN OVERLAY -->
<div id="login-overlay">
  <div class="login-box">
    <div class="login-logo">Hearing Benefit Services</div>
    <div class="login-divider"></div>
    <h2>Staff Portal</h2>
    <p>Internal use only — please sign in to continue</p>
    <input type="text" id="uname" placeholder="Username" autocomplete="username" />
    <input type="password" id="pword" placeholder="Password" autocomplete="current-password" />
    <button onclick="checkLogin()">Sign In</button>
    <p id="login-error">Incorrect username or password. Please try again.</p>
  </div>
</div>

<!-- MAIN CONTENT -->
<div id="main-content">

  <header>
    <div class="eyebrow">Internal Reference Document</div>
    <h1>Online Store Purchase Pipeline</h1>
    <p>Complete stage-by-stage guide for Andrea and Seteisha — how every online order moves from purchase to delivered customer.</p>
  </header>

  <nav class="sticky">
    <a href="#overview">Overview</a>
    <a href="#roles">Team Roles</a>
    <a href="#policies">Key Policies</a>
    <a href="#pipeline">Pipeline Stages</a>
    <a href="#tags">Tags Reference</a>
    <a href="#post-delivery">Post-Delivery</a>
    <a href="#feedback">Feedback Gate</a>
    <a href="#feedbackform">Feedback Form</a>
    <a href="#messages">Message Copy</a>
    <a href="#lapsed">Lapsed Orders</a>
    <a href="#feedbackform">Feedback Form</a>
  </nav>

  <div class="container">

    <!-- OVERVIEW -->
    <section id="overview">
      <h2>📋 Overview</h2>
      <p>When a customer purchases hearing aids from the HBS online store, their order does not ship immediately. Every order goes through a mandatory pre-shipment consultation with Seteisha before Andrea programs and ships the hearing aids.</p>
      <p>This document is your reference for every stage, who owns it, what tags are applied, and what automated messages go out.</p>

      <div class="success-box">
        ✅ <strong>The golden rule:</strong> Nothing ships until Seteisha completes the appointment and files the outcome form. Andrea programs and ships based on that form — no separate patient appointment needed.
      </div>

      <h3>Complete Post-Purchase Timeline</h3>
      <div class="timeline">
        <div class="timeline-item">
          <div class="day">Purchase</div>
          <strong>Order placed — hold begins</strong>
          <p>Payment collected. 30-day clock starts. Booking link sent automatically.</p>
        </div>
        <div class="timeline-item">
          <div class="day">WA/DE Only</div>
          <strong>Audiologist document required</strong>
          <p>Customer emails prescription to HBS before booking link is released.</p>
        </div>
        <div class="timeline-item">
          <div class="day">Seteisha</div>
          <strong>Virtual appointment + outcome form</strong>
          <p>Seteisha conducts assessment, files outcome form, orders from Signia.</p>
        </div>
        <div class="timeline-item">
          <div class="day">Andrea</div>
          <strong>Receives, programs, ships</strong>
          <p>Andrea receives aids from Signia, programs using outcome form, ships via PirateShip.</p>
        </div>
        <div class="timeline-item">
          <div class="day">Day 2</div>
          <strong>Check-in sent</strong>
          <p>Automated SMS + email asking how the hearing aids are feeling.</p>
        </div>
        <div class="timeline-item">
          <div class="day">Day 14</div>
          <strong>2-week follow-up sent</strong>
          <p>Automated SMS + email — how is the product doing, do they need help?</p>
        </div>
        <div class="timeline-item">
          <div class="day">Day 21</div>
          <strong>Feedback form sent</strong>
          <p>Customer rates experience 1–5 stars on HBS website form.</p>
        </div>
        <div class="timeline-item">
          <div class="day">Day 22+ (if 3–5 stars)</div>
          <strong>Review request sent</strong>
          <p>Links to Google, Facebook, and HBS website testimonials. Then moved to Current Client pipeline.</p>
        </div>
      </div>
    </section>

    <!-- TEAM ROLES -->
    <section id="roles">
      <h2>👥 Team Roles</h2>
      <table class="pipeline-table">
        <thead>
          <tr>
            <th>Team Member</th>
            <th>Pipeline Responsibilities</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="owner-badge owner-set">Seteisha Hall</span></td>
            <td>
              <ul style="margin:0; padding-left:18px;">
                <li>Conducts virtual hearing assessment</li>
                <li>Fills out outcome form completely (model, dome, receiver, all settings)</li>
                <li>Orders hearing aids via Signia website — ships to Andrea's address</li>
                <li>Reviews and approves WA/DE audiologist documents</li>
                <li>Marks GHL tasks complete to trigger next automation steps</li>
              </ul>
            </td>
          </tr>
          <tr>
            <td><span class="owner-badge owner-andrea">Andrea Sotolongo</span></td>
            <td>
              <ul style="margin:0; padding-left:18px;">
                <li>Receives hearing aids from Signia</li>
                <li>Programs hearing aids using Seteisha's outcome form — no patient appointment needed</li>
                <li>Creates shipping label in PirateShip</li>
                <li>Schedules UPS or FedEx pickup at her location</li>
                <li>Marks GHL tasks complete at each handoff point</li>
              </ul>
            </td>
          </tr>
        </tbody>
      </table>
    </section>

    <!-- KEY POLICIES -->
    <section id="policies">
      <h2>📌 Key Policies</h2>

      <div class="gold-box" style="margin-bottom:16px;">
        <strong>30-Day Hold Policy</strong><br>
        All orders are held after purchase until the pre-shipment appointment is completed. Customer has 30 days from purchase to complete their appointment or the order is automatically cancelled and fully refunded.<br><br>
        <span class="chip chip-amber">Day 15</span> Reminder SMS/email sent &nbsp;
        <span class="chip chip-amber">Day 25</span> Final warning sent &nbsp;
        <span class="chip chip-red">Day 30</span> Auto-cancelled — full refund issued
      </div>

      <div class="purple-box">
        <strong>Washington &amp; Delaware Rule</strong><br>
        These states require an in-person audiologist consultation before a hearing aid can be dispensed. Customers must email their audiologist prescription or recommendation letter to <strong>info@hearingbenefitservices.com</strong> before the booking link is released. Seteisha or Andrea reviews the document and approves before proceeding.
      </div>

      <div class="info-box" style="margin-top:16px;">
        <strong>Outcome Form = Programming Instructions</strong><br>
        The outcome form Seteisha fills out is the only source Andrea uses to program the hearing aids. It must be completed in full — model, dome size, receiver, and all relevant settings. Andrea will not contact the patient for programming information.
      </div>
    </section>

    <!-- PIPELINE STAGES -->
    <section id="pipeline">
      <h2>🗂️ Pipeline Stages</h2>

      <div class="legend">
        <div class="legend-item"><div class="legend-dot" style="background:#085041;"></div> Automated</div>
        <div class="legend-item"><div class="legend-dot" style="background:#1e3a5f;"></div> Seteisha</div>
        <div class="legend-item"><div class="legend-dot" style="background:#854f0b;"></div> Andrea</div>
        <div class="legend-item"><div class="legend-dot" style="background:#7c3aed;"></div> WA/DE only</div>
        <div class="legend-item"><div class="legend-dot" style="background:#444441;"></div> Customer</div>
        <div class="legend-item"><div class="legend-dot" style="background:#16a34a;"></div> Tag added automatically</div>
        <div class="legend-item"><div class="legend-dot" style="background:#b8972a;"></div> Tag added manually by team</div>
        <div class="legend-item"><div class="legend-dot" style="background:#fef2f2;border:1px dashed #fca5a5;"></div> Tag removed</div>
      </div>

      <table class="pipeline-table">
        <thead>
          <tr>
            <th style="width:42px;">#</th>
            <th>Stage</th>
            <th>Owner</th>
            <th>GHL Task / Tags</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="stage-num">1</span></td>
            <td>
              <strong>Purchase completed</strong><br>
              <span style="font-size:.82rem;color:#718096;">Order confirmed, payment collected, 30-day clock starts. Booking link SMS/email sent automatically.</span>
            </td>
            <td><span class="owner-badge owner-auto">Automated</span></td>
            <td>
              Add: <span class="tag tag-add">online-purchase</span> <span class="tag tag-add">order-hold</span>
            </td>
          </tr>
          <tr class="wade-row">
            <td><span class="stage-num stage-num-purple">2</span></td>
            <td>
              <strong>Awaiting audiologist document</strong><br>
              <span style="font-size:.82rem;color:#718096;">WA/DE only — customer emails prescription or recommendation letter to HBS.</span>
            </td>
            <td><span class="owner-badge owner-wade">WA/DE only</span></td>
            <td>
              Add: <span class="tag tag-add">wade-awaiting-doc</span><br>
              Remove: <span class="tag tag-remove">booking-link-sent</span>
            </td>
          </tr>
          <tr class="wade-row">
            <td><span class="stage-num stage-num-purple">3</span></td>
            <td>
              <strong>Document received &amp; reviewed</strong><br>
              <span style="font-size:.82rem;color:#718096;">WA/DE only — Seteisha or Andrea approves document. Triggers booking link to be sent.</span>
            </td>
            <td><span class="owner-badge owner-wade">WA/DE only</span></td>
            <td>
              Add: <span class="tag tag-add">wade-doc-approved</span><br>
              Remove: <span class="tag tag-remove">wade-awaiting-doc</span>
            </td>
          </tr>
          <tr>
            <td><span class="stage-num">4</span></td>
            <td>
              <strong>Booking link sent</strong><br>
              <span style="font-size:.82rem;color:#718096;">Customer receives SMS and email with appointment link.</span>
            </td>
            <td><span class="owner-badge owner-auto">Automated</span></td>
            <td>
              Add: <span class="tag tag-add">booking-link-sent</span>
            </td>
          </tr>
          <tr>
            <td><span class="stage-num">5</span></td>
            <td>
              <strong>Appointment booked</strong><br>
              <span style="font-size:.82rem;color:#718096;">Customer self-schedules via the booking link.</span>
            </td>
            <td><span class="owner-badge owner-cust">Customer</span></td>
            <td>
              Add: <span class="tag tag-add">appointment-booked</span><br>
              Remove: <span class="tag tag-remove">booking-link-sent</span>
            </td>
          </tr>
          <tr>
            <td><span class="stage-num">6</span></td>
            <td>
              <strong>Appointment completed — outcome form filed</strong><br>
              <span style="font-size:.82rem;color:#718096;">Seteisha conducts virtual assessment and fills outcome form in full.</span>
            </td>
            <td><span class="owner-badge owner-set">Seteisha</span></td>
            <td>
              Add: <span class="tag tag-add">outcome-form-filed</span><br>
              Remove: <span class="tag tag-remove">appointment-booked</span><br>
              <span style="font-size:.8rem;color:#4a5568;">✦ Mark task "Outcome form filed — ready to order" complete → triggers Andrea notification</span>
            </td>
          </tr>
          <tr>
            <td><span class="stage-num">7</span></td>
            <td>
              <strong>Hearing aid ordered on Signia</strong><br>
