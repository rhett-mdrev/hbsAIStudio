  <style>
    :root {
      --navy-deep:    #0B1E2B;
      --navy-mid:     #1B4965;
      --navy-light:   #2A64A7;
      --amber:        #FFC107;
      --amber-dark:   #e6a800;
      --emerald:      #10b981;
      --slate-100:    #f1f5f9;
      --slate-200:    #e2e8f0;
      --slate-600:    #475569;
      --slate-800:    #1e293b;
      --white:        #ffffff;
      --font-head:    'Lora', Georgia, serif;
      --font-body:    'Poppins', sans-serif;
      --radius:       12px;
      --shadow-sm:    0 2px 8px rgba(0,0,0,0.08);
      --shadow-md:    0 4px 20px rgba(0,0,0,0.12);
      --shadow-lg:    0 8px 40px rgba(0,0,0,0.16);
      --transition:   0.3s ease;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html  { scroll-behavior: smooth; font-size: 16px; }
    body  {
      font-family: var(--font-body);
      color: var(--slate-800);
      background: var(--white);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    h1, h2, h3, h4 { font-family: var(--font-head); line-height: 1.25; }
    h1 { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 700; }
    h2 { font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 700; }
    h3 { font-size: clamp(1.15rem, 2vw, 1.5rem); font-weight: 600; }
    p  { margin-bottom: 1rem; color: var(--slate-600); }
    a  { color: var(--navy-light); text-decoration: none; transition: color var(--transition); }
    a:hover { color: var(--navy-mid); }

    .container   { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
    .section     { width: 100%; padding: 5rem 0; }
    .section-alt { background: var(--slate-100); }
    .text-center { text-align: center; }

    .section-tag {
      display: inline-block;
      background: rgba(245,158,11,.15);
      color: #f59e0b;
      font-size: 0.75rem; font-weight: 600;
      letter-spacing: 0.12em; text-transform: uppercase;
      padding: 0.35rem 1rem; border-radius: 50px;
      margin-bottom: 1rem;
    }
    .section-intro {
      max-width: 680px; margin: 0 auto 3rem;
      font-size: 1.05rem; color: var(--slate-600); text-align: center;
    }

    /* ── Buttons ── */
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.85rem 2rem; border-radius: 50px;
      font-family: var(--font-body); font-weight: 600;
      font-size: 1rem; cursor: pointer; border: none;
      transition: all var(--transition); text-decoration: none;
    }
    .btn-primary {
      background: linear-gradient(135deg, var(--amber), var(--amber-dark));
      color: var(--navy-deep);
      box-shadow: 0 4px 18px rgba(255,193,7,0.35);
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 24px rgba(255,193,7,0.5); color: var(--navy-deep); }
    .btn-navy {
      background: linear-gradient(135deg, var(--navy-mid), var(--navy-deep));
      color: var(--white); box-shadow: var(--shadow-md);
    }
    .btn-navy:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); color: var(--white); }
    .btn-outline-navy {
      background: transparent; border: 2px solid var(--navy-light); color: var(--navy-light);
    }
    .btn-outline-navy:hover { background: var(--navy-light); color: var(--white); }
    .btn-outline-white {
      background: transparent; border: 2px solid var(--white); color: var(--white);
    }
    .btn-outline-white:hover { background: var(--white); color: var(--navy-mid); }
    .btn-full { display: flex; width: 100%; justify-content: center; border-radius: var(--radius); }

    /* ── Hero ── */
    .hero {
      width: 100%;
      background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy-mid) 55%, var(--navy-light) 100%);
      color: var(--white);
      padding: 6rem 0 5rem;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: ''; position: absolute; inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Ccircle cx='30' cy='30' r='4'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E") repeat;
      pointer-events: none;
    }
    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
      position: relative;
      z-index: 1;
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      backdrop-filter: blur(8px);
      padding: 0.4rem 1rem; border-radius: 50px;
      font-size: 0.8rem; font-weight: 600;
      letter-spacing: 0.06em; text-transform: uppercase;
      margin-bottom: 1.5rem; color: var(--amber);
    }
    .hero h1 { color: var(--white); margin-bottom: 1.25rem; }
    .hero h1 span { color: var(--amber); }
    .hero-subtitle {
      font-size: 1.1rem; opacity: 0.88;
      margin-bottom: 2rem; line-height: 1.75;
      color: var(--white);
    }
    .hero-actions { display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; }
    .hero-contact-bar { margin-top: 2.5rem; display: flex; flex-wrap: wrap; gap: 1.25rem; }
    .hero-contact-pill {
      display: flex; align-items: center; gap: 0.6rem;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 50px; padding: 0.55rem 1.1rem;
      font-size: 0.9rem; font-weight: 500;
      color: rgba(255,255,255,0.92);
      text-decoration: none; transition: all var(--transition);
    }
    .hero-contact-pill:hover { background: rgba(255,255,255,0.2); color: var(--white); }
    .hero-contact-pill svg { color: var(--amber); flex-shrink: 0; }

    .hero-visual { display: flex; flex-direction: column; gap: 1rem; }
    .hero-card {
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.18);
      backdrop-filter: blur(12px);
      border-radius: var(--radius); padding: 1.5rem;
    }
    .hero-card-title {
      font-size: 0.75rem; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--amber);
      font-weight: 600; margin-bottom: 1rem;
    }
    .stat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
    .stat-chip {
      background: rgba(255,255,255,0.07);
      border-radius: 8px; padding: 0.85rem 1rem; text-align: center;
    }
    .stat-chip .num { display: block; font-size: 1.5rem; font-weight: 700; color: var(--amber); font-family: var(--font-head); }
    .stat-chip .lbl { font-size: 0.72rem; opacity: 0.82; color: var(--white); }
    .hours-list { display: flex; flex-direction: column; gap: 0.5rem; }
    .hours-row {
      display: flex; justify-content: space-between; align-items: center;
      background: rgba(255,255,255,0.06); border-radius: 8px;
      padding: 0.55rem 0.9rem; font-size: 0.85rem;
    }
    .hours-row .day  { font-weight: 500; opacity: 0.85; color: var(--white); }
    .hours-row .time { color: var(--amber); font-weight: 600; }
    .hours-row .badge-online {
      font-size: 0.68rem; font-weight: 700;
      background: var(--emerald); color: var(--white);
      padding: 0.15rem 0.5rem; border-radius: 4px;
    }

    /* ── Trust Strip ── */
    .trust-strip { width: 100%; background: var(--navy-deep); padding: 1.25rem 0; }
    .trust-strip-inner {
      display: flex; flex-wrap: wrap;
      justify-content: center; gap: 2rem 3rem;
    }
    .trust-item {
      display: flex; align-items: center; gap: 0.6rem;
      color: rgba(255,255,255,0.85); font-size: 0.85rem; font-weight: 500;
    }
    .trust-item svg { color: var(--amber); flex-shrink: 0; }

    /* ── Contact Cards ── */
    .contact-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem; align-items: start;
    }
    .contact-card {
      background: var(--white); border-radius: var(--radius);
      border: 1px solid var(--slate-200); box-shadow: var(--shadow-sm);
      overflow: hidden; display: flex; flex-direction: column;
      transition: all var(--transition);
    }
    .contact-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-md); border-color: var(--navy-light); }
    .contact-card.featured {
      border: 2px solid var(--navy-light); box-shadow: var(--shadow-md);
      transform: translateY(-8px);
    }
    .contact-card.featured:hover { transform: translateY(-12px); box-shadow: var(--shadow-lg); }
    .card-header {
      padding: 2rem 2rem 1.5rem;
      display: flex; flex-direction: column; align-items: center; text-align: center;
    }
    .card-icon {
      width: 64px; height: 64px; border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1.25rem; font-size: 1.6rem;
    }
    .card-header h3 { color: var(--navy-deep); margin-bottom: 0.6rem; }
    .card-header p  { font-size: 0.88rem; margin: 0; }
    .card-body  { padding: 0 2rem 2rem; flex: 1; display: flex; flex-direction: column; gap: 0.75rem; }
    .card-meta  { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: var(--slate-600); }
    .card-meta svg { color: var(--emerald); flex-shrink: 0; }
    .card-footer { padding: 0 2rem 2rem; margin-top: auto; }
    .featured-ribbon {
      background: linear-gradient(135deg, var(--amber), var(--amber-dark));
      color: var(--navy-deep); font-size: 0.72rem; font-weight: 700;
      letter-spacing: 0.08em; text-transform: uppercase;
      text-align: center; padding: 0.4rem;
    }

    /* ── Stats Band ── */
    .stats-band {
      width: 100%;
      background: linear-gradient(135deg, var(--navy-mid), var(--navy-deep));
