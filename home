    /* ── LOYALTY ── */
    .loyalty-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:22px; }
    .loyalty-card {
      background:#fff; border:1px solid var(--slate-200);
