    .hh-article-icon-wrap { padding: 28px 28px 0; display: flex; align-items: center; justify-content: space-between; }
    .hh-article-icon { width: 52px; height: 52px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; font-size: 1.4rem; flex-shrink: 0; }
    .hh-article-tag { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 3px 10px; border-radius: 50px; background: rgba(255,193,7,0.2); color: var(--gold); }
    .hh-article-body { padding: 16px 28px 24px; flex: 1; display: flex; flex-direction: column; }
    .hh-article-body h3 { color: #fff; font-size: 1rem; font-weight: 700; margin-bottom: 8px; line-height: 1.4; }
    .hh-article-body p  { color: rgba(255,255,255,0.65); font-size: 0.84rem; line-height: 1.65; margin-bottom: 16px; flex: 1; }
