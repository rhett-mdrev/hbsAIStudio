  <style>
    :root {
      --navy:        #0B1E2B;
      --blue-dark:   #1B4965;
      --blue:        #2A64A7;
      --blue-mid:    #3578c7;
      --gold:        #FFC107;
      --gold-dark:   #e6a800;
      --green:       #10b981;
      --red:         #ef4444;
      --teal:        #0ea5e9;
      --light:       #F8FAFC;
      --slate-100:   #f1f5f9;
      --slate-200:   #e2e8f0;
      --slate-500:   #64748b;
      --slate-700:   #334155;
      --white:       #ffffff;
      --radius-sm:   10px;
      --radius-md:   16px;
      --radius-lg:   24px;
      --shadow-sm:   0 2px 12px rgba(0,0,0,0.06);
      --shadow-md:   0 8px 32px rgba(0,0,0,0.11);
      --shadow-lg:   0 20px 60px rgba(0,0,0,0.15);
      --shadow-gold: 0 6px 28px rgba(255,193,7,0.38);
      --transition:  all 0.25s ease;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Poppins', sans-serif;
      background: var(--white);
      color: var(--slate-700);
      font-size: 1.02rem;
      line-height: 1.8;
      overflow-x: hidden;
    }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; display: block; }
    h1 { font-family: 'Lora', serif; font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 700; line-height: 1.12; }
    h2 { font-family: 'Lora', serif; font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 700; line-height: 1.22; color: var(--navy); margin-bottom: 14px; }
    h3 { font-family: 'Poppins', sans-serif; font-size: clamp(1.05rem, 2vw, 1.25rem); font-weight: 700; color: var(--blue-dark); margin-bottom: 8px; }
    p { margin-bottom: 16px; }
    p:last-child { margin-bottom: 0; }
    strong { font-weight: 700; }

    /* ── LAYOUT ── */
    .section-inner   { max-width: 1080px; margin: 0 auto; padding: 0 1.5rem; }
    .section-gap     { padding: 88px 0; }
    .section-divider { height: 1px; background: var(--slate-200); margin: 0 auto; max-width: 960px; }

    /* ── FULL-BLEED ── */
    .full-bleed {
      position: relative;
      left: 50%;
      right: 50%;
      margin-left: -50vw !important;
      margin-right: -50vw !important;
      width: 100vw !important;
      max-width: 100vw !important;
      box-sizing: border-box;
    }

    /* ── HERO ── */
    .hero {
      background: linear-gradient(135deg, #0B1E2B 0%, #1B4965 50%, #2A64A7 100%) !important;
      padding: 110px 1.5rem 90px;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at 65% 40%, rgba(255,193,7,0.10) 0%, transparent 60%);
      pointer-events: none;
    }
    .pulse-rings { position: absolute; top: 50%; left: 25%; transform: translate(-50%,-50%); pointer-events: none; z-index: 0; }
    .p-ring { position: absolute; border-radius: 50%; border: 1px solid rgba(255,193,7,0.07); top: 50%; left: 50%; transform: translate(-50%,-50%); animation: pulse-out 5s ease-out infinite; }
    .p-ring:nth-child(1){width:200px;height:200px;animation-delay:0s;}
    .p-ring:nth-child(2){width:450px;height:450px;animation-delay:1.2s;}
    .p-ring:nth-child(3){width:700px;height:700px;animation-delay:2.4s;}
    .p-ring:nth-child(4){width:950px;height:950px;animation-delay:3.6s;}
    @keyframes pulse-out{0%{opacity:0.7;}100%{opacity:0;}}
    .hero-inner {
      max-width: 1080px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 60px; align-items: center;
      position: relative; z-index: 1;
    }
    @media(max-width:860px){ .hero-inner{ grid-template-columns:1fr; text-align:center; } }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--gold); color: #000;
      font-size: 0.75rem; font-weight: 900;
      text-transform: uppercase; letter-spacing: 0.09em;
      padding: 7px 20px; border-radius: 50px;
      box-shadow: var(--shadow-gold); margin-bottom: 22px;
    }
    .hero h1 { color: #fff; margin-bottom: 22px; }
    .hero h1 span { color: #7dd3fc; }
    .hero-lead {
      color: rgba(255,255,255,0.82); font-size: 1.12rem;
      max-width: 520px; margin-bottom: 36px; line-height: 1.75;
    }
    @media(max-width:860px){ .hero-lead{ margin-left:auto; margin-right:auto; } }
    .hero-lead strong { color: #fff; }
    .hero-btns { display: flex; flex-wrap: wrap; gap: 14px; }
    @media(max-width:860px){ .hero-btns{ justify-content:center; } }

    /* ── BUTTONS ── */
    .btn-gold {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--gold); color: #000;
      font-family: 'Poppins', sans-serif; font-weight: 900; font-size: 1rem;
      padding: 15px 34px; border-radius: 50px;
      box-shadow: var(--shadow-gold);
      border-bottom: 4px solid var(--gold-dark);
      border-left: none; border-right: none; border-top: none;
      transition: var(--transition); cursor: pointer;
    }
    .btn-gold:hover { transform: scale(1.05) translateY(-2px); box-shadow: 0 14px 44px rgba(255,193,7,0.55); }
    .btn-outline-white {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent; color: #fff;
      font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 1rem;
      padding: 15px 34px; border-radius: 50px;
      border: 2px solid rgba(255,255,255,0.55);
      transition: var(--transition); cursor: pointer;
    }
    .btn-outline-white:hover { background: rgba(255,255,255,0.1); border-color:#fff; transform:translateY(-2px); }

    /* ── HERO IMAGE ── */
    .hero-img-wrap {
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-lg);
      border: 1px solid rgba(255,255,255,0.12);
    }
    .hero-img-wrap img { width: 100%; height: auto; display: block; }

    /* ── TRUST STRIP ── */
    .trust-strip { background: var(--navy) !important; padding: 16px 1.5rem; border-bottom: 3px solid var(--gold); }
    .trust-inner {
      max-width: 1080px; margin: 0 auto;
      display: flex; flex-wrap: wrap;
      gap: 8px 32px; align-items: center; justify-content: center;
    }
    .trust-item { display:flex; align-items:center; gap:8px; font-size:0.78rem; font-weight:600; color:rgba(255,255,255,0.85); white-space:nowrap; }
    .trust-item i { color:var(--gold); font-size:0.85rem; }

    /* ── BADGES ── */
    .badge { display:inline-flex; align-items:center; gap:6px; padding:6px 16px; border-radius:50px; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; margin-bottom:14px; }
    .badge-blue  { background:rgba(27,73,101,0.1);  color:var(--blue-dark); }
    .badge-gold  { background:rgba(255,193,7,0.12); color:#92640a; }
    .badge-green { background:rgba(16,185,129,0.1); color:#065f46; }
    .badge-navy  { background:rgba(11,30,43,0.08);  color:var(--navy); }

    /* ── SECTION HEADERS ── */
    .section-hdr { text-align:center; margin-bottom:52px; }
    .section-hdr p { color:var(--slate-500); max-width:640px; margin:0 auto; font-size:1rem; }

    /* ── STEPS ── */
    .steps-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:28px; }
    .step-card {
      background:#fff; border:1px solid var(--slate-200);
      border-radius:var(--radius-md); padding:34px 26px 28px;
      box-shadow:var(--shadow-sm); text-align:center;
      position:relative; transition:var(--transition);
    }
    .step-card:hover { transform:translateY(-5px); box-shadow:var(--shadow-md); }
    .step-card::before {
      content:''; position:absolute; top:0; left:0; right:0; height:4px;
      border-radius:var(--radius-md) var(--radius-md) 0 0;
      background:linear-gradient(90deg, var(--gold), var(--blue));
    }
    .step-num {
      width:60px; height:60px; border-radius:50%;
      background:linear-gradient(135deg, var(--blue-dark), var(--blue));
      color:#fff; font-family:'Lora',serif; font-size:1.5rem; font-weight:700;
      display:flex; align-items:center; justify-content:center;
      margin:0 auto 18px; box-shadow:0 4px 18px rgba(27,73,101,0.28);
      transition:var(--transition);
    }
    .step-card:hover .step-num { background:var(--gold); color:#000; box-shadow:var(--shadow-gold); }
    .step-icon-wrap {
      width:72px; height:72px; border-radius:50%;
      background:rgba(42,100,167,0.08);
      display:flex; align-items:center; justify-content:center;
      margin:0 auto 18px; font-size:1.8rem;
    }

    /* ── FEATURES ── */
    .features-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(210px,1fr)); gap:20px; }
    .feature-card {
      background:#fff; border:1px solid var(--slate-200);
      border-radius:var(--radius-md); padding:28px 22px;
      box-shadow:var(--shadow-sm); transition:var(--transition);
    }
    .feature-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-md); }
    .feature-icon { width:58px; height:58px; border-radius:var(--radius-sm); display:flex; align-items:center; justify-content:center; font-size:1.5rem; margin-bottom:16px; }
    .feature-icon.blue  { background:rgba(42,100,167,0.09); }
    .feature-icon.gold  { background:rgba(255,193,7,0.12); }
    .feature-icon.green { background:rgba(16,185,129,0.09); }
    .feature-icon.navy  { background:rgba(11,30,43,0.07); }
    .feature-card h3 { font-size:0.98rem; margin-bottom:6px; }
    .feature-card p  { font-size:0.84rem; color:var(--slate-500); margin-bottom:0; line-height:1.65; }

    /* ── BENEFITS ── */
    .benefits-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:20px; }
    .benefit-card {
      background:#fff; border:1px solid var(--slate-200);
      border-radius:var(--radius-md); padding:28px 22px;
      text-align:center; box-shadow:var(--shadow-sm);
      transition:var(--transition); position:relative; overflow:hidden;
    }
    .benefit-card::before { content:''; position:absolute; top:0; left:0; right:0; height:4px; }
    .benefit-card.bc1::before { background:var(--blue); }
    .benefit-card.bc2::before { background:var(--gold); }
    .benefit-card.bc3::before { background:var(--green); }
    .benefit-card.bc4::before { background:var(--navy); }
    .benefit-card:hover { transform:translateY(-5px); box-shadow:var(--shadow-md); }
    .bicon { font-size:2rem; margin-bottom:14px; display:block; }

    /* ── WHY ── */
    .why-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:22px; }
    .why-card {
      background:#fff; border:1px solid var(--slate-200);
      border-radius:var(--radius-md); padding:32px 26px;
      box-shadow:var(--shadow-sm); transition:var(--transition);
    }
    .why-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-md); }
    .why-icon {
      width:66px; height:66px; border-radius:50%;
      background:rgba(27,73,101,0.08);
      display:flex; align-items:center; justify-content:center;
      font-size:1.6rem; margin-bottom:18px;
    }

    /* ══════════════════════════════════════
       HEARING HEALTH BANNER
    ══════════════════════════════════════ */
    .hh-banner {
      background: linear-gradient(135deg, #0B1E2B 0%, #1B4965 55%, #2A64A7 100%) !important;
      padding: 80px 1.5rem;
      position: relative;
      overflow: hidden;
    }
    .hh-banner::before {
      content: '';
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse at 20% 50%, rgba(255,193,7,0.13) 0%, transparent 55%),
        radial-gradient(ellipse at 80% 20%, rgba(14,165,233,0.10) 0%, transparent 50%);
      pointer-events: none;
    }
    .hh-banner-inner { max-width: 1080px; margin: 0 auto; position: relative; z-index: 1; }
    .hh-banner-header { text-align: center; margin-bottom: 56px; }
    .hh-banner-header h2 { color: #fff; font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 14px; }
    .hh-banner-header p  { color: rgba(255,255,255,0.75); max-width: 600px; margin: 0 auto; font-size: 1.02rem; }

    .hh-stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-bottom: 64px; }
    @media(max-width:760px){ .hh-stats{ grid-template-columns:repeat(2,1fr); } }
    @media(max-width:420px){ .hh-stats{ grid-template-columns:1fr; } }
    .hh-stat {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.13);
      border-radius: var(--radius-md); padding: 24px 16px;
      text-align: center; transition: var(--transition);
    }
    .hh-stat:hover { background: rgba(255,255,255,0.12); transform: translateY(-3px); }
    .hh-stat-num {
      font-family: 'Lora', serif; font-size: 2rem; font-weight: 700;
      background: linear-gradient(135deg, var(--gold), #7dd3fc);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; display: block; margin-bottom: 6px; line-height: 1.1;
    }
    .hh-stat-label { font-size: 0.78rem; color: rgba(255,255,255,0.72); font-weight: 500; line-height: 1.4; }

    .hh-articles { display: grid; grid-template-columns: repeat(3,1fr); gap: 22px; margin-bottom: 48px; }
    @media(max-width:860px){ .hh-articles{ grid-template-columns:repeat(2,1fr); } }
    @media(max-width:560px){ .hh-articles{ grid-template-columns:1fr; } }
    .hh-article-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: var(--radius-md); overflow: hidden;
      transition: var(--transition);
      display: flex; flex-direction: column;
    }
    .hh-article-card:hover {
      background: rgba(255,255,255,0.11);
