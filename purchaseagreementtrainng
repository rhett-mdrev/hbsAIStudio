<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Patient Agreement Generator | HBS Staff Training</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #0d1f3c;
  --navy-mid: #1a3560;
  --blue: #1d6fa4;
  --blue-light: #3a9fd4;
  --gold: #c98a2a;
  --gold-light: #e8b354;
  --cream: #f7f4ef;
  --white: #ffffff;
  --gray-50: #f9fafb;
  --gray-100: #f1f3f6;
  --gray-200: #e2e8f0;
  --gray-400: #94a3b8;
  --gray-600: #475569;
  --gray-800: #1e293b;
  --green: #15803d;
  --green-bg: #f0fdf4;
  --green-border: #bbf7d0;
  --red: #dc2626;
  --red-bg: #fef2f2;
  --amber: #d97706;
  --amber-bg: #fffbeb;
  --amber-border: #fde68a;
  --purple: #7c3aed;
  --purple-bg: #f5f3ff;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--gray-800);
  line-height: 1.7;
}

/* ── TOP NAV ── */
.top-nav {
  background: var(--white);
  border-bottom: 1px solid var(--gray-200);
  padding: 14px 40px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.nav-left { display: flex; align-items: center; gap: 16px; }
.nav-logo { height: 32px; }
.nav-divider { width: 1px; height: 24px; background: var(--gray-200); }
.nav-title { font-size: 13px; font-weight: 600; color: var(--gray-600); letter-spacing: 0.5px; }
.nav-right { display: flex; align-items: center; gap: 12px; }
.nav-badge {
  background: var(--green-bg);
  color: var(--green);
  border: 1px solid var(--green-border);
  font-size: 11px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 20px;
  letter-spacing: 0.3px;
}
.nav-back {
  font-size: 12px;
  color: var(--blue);
  text-decoration: none;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 4px;
}
.nav-back:hover { text-decoration: underline; }

/* ── HERO ── */
.hero {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 55%, #1a4a7a 100%);
  padding: 72px 40px 64px;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -100px; right: -60px;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(29,111,164,0.25) 0%, transparent 65%);
  border-radius: 50%;
  pointer-events: none;
}
.hero::after {
  content: '';
  position: absolute;
  bottom: -80px; left: 30%;
  width: 350px; height: 350px;
  background: radial-gradient(circle, rgba(201,138,42,0.12) 0%, transparent 65%);
  border-radius: 50%;
  pointer-events: none;
}
.hero-inner { max-width: 860px; margin: 0 auto; position: relative; z-index: 1; }
.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 20px;
  padding: 6px 14px;
  margin-bottom: 24px;
}
.hero-eyebrow span {
  font-size: 11px;
  font-weight: 600;
  color: rgba(255,255,255,0.75);
  letter-spacing: 1.5px;
  text-transform: uppercase;
  font-family: 'DM Mono', monospace;
}
.hero-dot { width: 6px; height: 6px; background: var(--gold-light); border-radius: 50%; }
.hero h1 {
  font-family: 'DM Serif Display', serif;
  font-size: 42px;
  color: var(--white);
  line-height: 1.15;
  margin-bottom: 16px;
}
.hero h1 em {
  font-style: italic;
  color: var(--gold-light);
}
.hero-sub {
  font-size: 16px;
  color: rgba(255,255,255,0.65);
  max-width: 580px;
  margin-bottom: 36px;
  font-weight: 300;
}
.hero-meta {
  display: flex;
  gap: 32px;
  flex-wrap: wrap;
}
.hero-meta-item {
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.hero-meta-label {
  font-size: 10px;
  font-weight: 600;
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  font-family: 'DM Mono', monospace;
}
.hero-meta-value {
  font-size: 14px;
  font-weight: 500;
  color: rgba(255,255,255,0.85);
}

/* ── MAIN LAYOUT ── */
.main { max-width: 900px; margin: 0 auto; padding: 48px 40px 80px; }

/* ── SECTION HEADERS ── */
.section-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 24px;
  margin-top: 52px;
}
.section-header:first-child { margin-top: 0; }
.section-icon {
  width: 36px; height: 36px;
  background: var(--navy);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
}
.section-title {
  font-family: 'DM Serif Display', serif;
  font-size: 22px;
  color: var(--navy);
}
.section-line {
  flex: 1;
  height: 1px;
  background: var(--gray-200);
}

/* ── OVERVIEW CARD ── */
.overview-card {
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: 14px;
  padding: 28px 32px;
  margin-bottom: 12px;
  box-shadow: 0 1px 6px rgba(0,0,0,0.04);
}
.overview-card p {
  font-size: 15px;
  color: var(--gray-600);
  margin-bottom: 20px;
}
.overview-card p:last-child { margin-bottom: 0; }
.overview-card strong { color: var(--gray-800); font-weight: 600; }

/* ── PURPOSE GRID ── */
.purpose-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 0;
}
.purpose-card {
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: 12px;
  padding: 22px 24px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}
.purpose-card-icon { font-size: 22px; margin-bottom: 10px; }
.purpose-card h4 {
  font-size: 13px;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 6px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.purpose-card p {
  font-size: 13px;
  color: var(--gray-600);
  line-height: 1.6;
}

/* ── WORKFLOW STEPS ── */
.workflow-container {
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 1px 6px rgba(0,0,0,0.04);
}
.workflow-step {
  display: grid;
  grid-template-columns: 56px 1fr;
  border-bottom: 1px solid var(--gray-100);
  transition: background 0.15s;
}
.workflow-step:last-child { border-bottom: none; }
.workflow-step:hover { background: var(--gray-50); }
.step-num {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 22px 0 22px;
  position: relative;
}
.step-num-inner {
  width: 28px; height: 28px;
  background: var(--navy);
  color: var(--white);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px;
  font-weight: 700;
  font-family: 'DM Mono', monospace;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}
.step-num::after {
  content: '';
  position: absolute;
  top: 50px; left: 50%;
  transform: translateX(-50%);
  width: 2px;
  height: calc(100% - 50px);
  background: var(--gray-200);
}
.workflow-step:last-child .step-num::after { display: none; }
.step-body {
  padding: 20px 24px 20px 12px;
}
.step-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 6px;
  flex-wrap: wrap;
}
.step-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--gray-800);
}
.step-type {
  font-size: 10px;
  font-weight: 700;
  padding: 3px 9px;
  border-radius: 12px;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  font-family: 'DM Mono', monospace;
}
.type-trigger { background: #fef3c7; color: #92400e; }
.type-opportunity { background: #ede9fe; color: #5b21b6; }
.type-document { background: #dbeafe; color: #1e40af; }
.type-wait { background: #f1f5f9; color: #475569; }
.type-notify { background: #d1fae5; color: #065f46; }
.type-manual { background: #fee2e2; color: #991b1b; }

.step-desc {
  font-size: 13px;
  color: var(--gray-600);
  margin-bottom: 10px;
  line-height: 1.6;
}
.step-fields {
  background: var(--gray-50);
  border: 1px solid var(--gray-200);
  border-radius: 8px;
  overflow: hidden;
  font-size: 12px;
}
.step-field {
  display: grid;
  grid-template-columns: 140px 1fr;
  border-bottom: 1px solid var(--gray-200);
}
.step-field:last-child { border-bottom: none; }
.field-label {
  padding: 8px 12px;
  font-weight: 600;
  color: var(--gray-600);
  background: var(--gray-100);
  border-right: 1px solid var(--gray-200);
  font-family: 'DM Mono', monospace;
  font-size: 11px;
}
.field-value {
  padding: 8px 12px;
  color: var(--gray-800);
  font-weight: 500;
}
.field-value code {
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  background: var(--gray-200);
  padding: 1px 6px;
  border-radius: 4px;
  color: var(--blue);
}

/* ── MANUAL STEP ── */
.manual-block {
  background: var(--amber-bg);
  border: 1px solid var(--amber-border);
  border-radius: 10px;
  padding: 16px 18px;
  margin: 8px 0;
  display: flex;
  gap: 12px;
  align-items: flex-start;
}
.manual-block-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
.manual-block-content {}
.manual-block-title {
  font-size: 12px;
  font-weight: 700;
  color: var(--amber);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 4px;
}
.manual-block-text {
  font-size: 13px;
  color: #78350f;
  line-height: 1.6;
}

/* ── SETEISHA CHECKLIST ── */
.checklist-card {
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 1px 6px rgba(0,0,0,0.04);
}
.checklist-header {
  background: var(--navy);
  padding: 18px 24px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.checklist-header h3 {
  font-size: 15px;
  font-weight: 600;
  color: var(--white);
}
.checklist-header-sub {
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  margin-top: 2px;
}
.checklist-item {
  display: flex;
  gap: 14px;
  padding: 16px 24px;
  border-bottom: 1px solid var(--gray-100);
  align-items: flex-start;
}
.checklist-item:last-child { border-bottom: none; }
.checklist-box {
  width: 20px; height: 20px;
  border: 2px solid var(--gray-300);
  border-radius: 4px;
  flex-shrink: 0;
  margin-top: 1px;
}
.checklist-text { font-size: 14px; color: var(--gray-700); line-height: 1.6; }
.checklist-text strong { color: var(--gray-800); font-weight: 600; }
.checklist-num {
  width: 22px; height: 22px;
  background: var(--blue);
  color: var(--white);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px;
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 1px;
}

/* ── PIPELINE STAGES ── */
.pipeline-flow {
  display: flex;
  flex-direction: column;
  gap: 0;
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 1px 6px rgba(0,0,0,0.04);
}
.pipeline-stage {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 14px 24px;
  border-bottom: 1px solid var(--gray-100);
  position: relative;
}
.pipeline-stage:last-child { border-bottom: none; }
.pipeline-stage-num {
  width: 28px; height: 28px;
  background: var(--gray-100);
  color: var(--gray-600);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px;
  font-weight: 700;
  font-family: 'DM Mono', monospace;
  flex-shrink: 0;
}
.pipeline-stage-name {
  font-size: 14px;
  font-weight: 500;
  color: var(--gray-800);
  flex: 1;
}
.pipeline-stage-note {
  font-size: 12px;
  color: var(--gray-400);
  font-style: italic;
}
.pipeline-stage.auto .pipeline-stage-num { background: #dbeafe; color: #1e40af; }
.pipeline-stage.manual .pipeline-stage-num { background: var(--amber-bg); color: var(--amber); }

/* ── IMPORTANT NOTES ── */
.notes-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
.note-card {
  border-radius: 12px;
  padding: 18px 20px;
  border: 1px solid;
}
.note-card.warning {
  background: var(--amber-bg);
  border-color: var(--amber-border);
}
.note-card.info {
  background: #eff6ff;
  border-color: #bfdbfe;
}
.note-card.success {
  background: var(--green-bg);
  border-color: var(--green-border);
}
.note-card.tip {
  background: var(--purple-bg);
  border-color: #ddd6fe;
}
.note-card-icon { font-size: 20px; margin-bottom: 8px; }
.note-card h4 {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 6px;
}
.note-card.warning h4 { color: var(--amber); }
.note-card.info h4 { color: #1d4ed8; }
.note-card.success h4 { color: var(--green); }
.note-card.tip h4 { color: var(--purple); }
.note-card p { font-size: 13px; color: var(--gray-700); line-height: 1.6; }

/* ── FOOTER ── */
.footer {
  background: var(--navy);
  padding: 32px 40px;
  text-align: center;
  margin-top: 60px;
}
.footer img { height: 28px; opacity: 0.6; margin-bottom: 10px; }
.footer p { font-size: 12px; color: rgba(255,255,255,0.35); }

/* ── DIVIDER ── */
.auto-label {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 10px;
  font-weight: 700;
  color: #1e40af;
  background: #dbeafe;
  border-radius: 10px;
  padding: 2px 8px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.manual-label {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 10px;
  font-weight: 700;
  color: #92400e;
  background: #fef3c7;
  border-radius: 10px;
  padding: 2px 8px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.separator {
  text-align: center;
  padding: 10px 0;
  position: relative;
}
.separator::before {
  content: '';
  position: absolute;
  top: 50%; left: 0; right: 0;
  height: 1px;
  background: var(--gray-200);
}
.separator span {
  position: relative;
  background: var(--cream);
  padding: 0 12px;
  font-size: 11px;
  color: var(--gray-400);
  font-family: 'DM Mono', monospace;
  text-transform: uppercase;
  letter-spacing: 1px;
}
</style>
</head>
<body>

<!-- TOP NAV -->
<nav class="top-nav">
  <div class="nav-left">
    <img class="nav-logo" src="https://assets.cdn.filesafe.space/UDKdmJIdT4xB1V6Lye64/media/68f7cb4d3a4642fd12cdeaab.png" alt="HBS Logo">
    <div class="nav-divider"></div>
    <span class="nav-title">Staff Training</span>
  </div>
  <div class="nav-right">
    <span class="nav-badge">● Live</span>
    <a class="nav-back" href="https://hearingbenefitservices.com/hbstraininghub">← Training Hub</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div class="hero-eyebrow">
      <div class="hero-dot"></div>
      <span>Workflow Training</span>
    </div>
    <h1>Patient Agreement <em>Generator</em></h1>
    <p class="hero-sub">Automates purchase agreement creation, tracks 45-day trial periods, and alerts Seteisha 7 days before — and on the day — a trial expires.</p>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <span class="hero-meta-label">Assigned To</span>
        <span class="hero-meta-value">Seteisha Hall</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-meta-label">Trigger</span>
        <span class="hero-meta-value">Patient Agreement Trigger Form</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-meta-label">Pipeline</span>
        <span class="hero-meta-value">Patient Agreements Device Sales</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-meta-label">Trial Duration</span>
        <span class="hero-meta-value">45 Days</span>
      </div>
    </div>
  </div>
</section>

<!-- MAIN -->
<main class="main">

  <!-- OVERVIEW -->
  <div class="section-header">
    <div class="section-icon">📋</div>
    <h2 class="section-title">Overview</h2>
    <div class="section-line"></div>
  </div>

  <div class="overview-card">
    <p>This workflow fires the moment a patient submits the <strong>Patient Agreement Trigger Form</strong>. It immediately creates a pipeline opportunity, generates a draft purchase agreement for Seteisha to review, then waits for the <strong>Trial Expiry Date</strong> to be filled in. Once that date is set, the system automatically notifies Seteisha <strong>7 days before</strong> the trial ends and again <strong>on the day it expires</strong>.</p>
    <p>This workflow handles special cases — patients on a 45-day trial period before full purchase commitment. The automation ensures no trial slips through the cracks without a follow-up.</p>
  </div>

  <div class="purpose-grid" style="margin-top:12px;">
    <div class="purpose-card">
      <div class="purpose-card-icon">⚡</div>
      <h4>What's Automated</h4>
      <p>Opportunity creation, agreement draft generation, countdown timing, and both expiry notifications — all automatic once the form is submitted and the trial date is set.</p>
    </div>
    <div class="purpose-card">
      <div class="purpose-card-icon">🙋</div>
      <h4>What Seteisha Does</h4>
      <p>Reviews and customizes the agreement draft, sends it to the patient, moves the pipeline stage manually as the patient progresses, and fills in the Trial Expiry Date after payment.</p>
    </div>
  </div>

  <!-- WORKFLOW STEPS -->
  <div class="section-header">
    <div class="section-icon">🔄</div>
    <h2 class="section-title">Workflow Steps</h2>
    <div class="section-line"></div>
  </div>

  <div class="workflow-container">

    <!-- TRIGGER -->
    <div class="workflow-step">
      <div class="step-num"><div class="step-num-inner">T</div></div>
      <div class="step-body">
        <div class="step-header">
          <span class="step-name">Form Submitted</span>
          <span class="step-type type-trigger">Trigger</span>
          <span class="auto-label">⚡ Auto</span>
        </div>
        <p class="step-desc">Workflow starts the instant the patient submits the intake form.</p>
        <div class="step-fields">
          <div class="step-field">
            <div class="field-label">Trigger Type</div>
            <div class="field-value">Form Submitted</div>
          </div>
          <div class="step-field">
            <div class="field-label">Form</div>
            <div class="field-value">Patient Agreement Trigger Form — <a href="https://hearingbenefitservices.com/patientpurchaseagreement" target="_blank" style="color:var(--blue);font-weight:600;">hearingbenefitservices.com/patientpurchaseagreement</a></div>
          </div>
        </div>
      </div>
    </div>

    <!-- CREATE OPP -->
    <div class="workflow-step">
      <div class="step-num"><div class="step-num-inner">1</div></div>
      <div class="step-body">
        <div class="step-header">
          <span class="step-name">Create Opportunity</span>
          <span class="step-type type-opportunity">Opportunity</span>
          <span class="auto-label">⚡ Auto</span>
        </div>
        <p class="step-desc">Creates a tracking card in the Patient Agreements Device Sales pipeline so the team can see where this patient stands.</p>
        <div class="step-fields">
          <div class="step-field">
            <div class="field-label">Pipeline</div>
            <div class="field-value">Patient Agreements Device Sales</div>
          </div>
          <div class="step-field">
            <div class="field-label">Stage</div>
            <div class="field-value">Form Submitted</div>
          </div>
          <div class="step-field">
            <div class="field-label">Opportunity Name</div>
            <div class="field-value"><code>{{contact.name}} - Agreement</code></div>
          </div>
          <div class="step-field">
            <div class="field-label">Source</div>
            <div class="field-value">Trigger Form</div>
          </div>
        </div>
      </div>
    </div>

    <!-- SEND DOCS -->
    <div class="workflow-step">
      <div class="step-num"><div class="step-num-inner">2</div></div>
      <div class="step-body">
        <div class="step-header">
