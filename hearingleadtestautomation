<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HBS Training — Hearing Test Lead Automation</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css" />

  <style>
    :root {
      --navy: #0B1E2B;
      --blue-dark: #1B4965;
      --blue: #2A64A7;
      --blue-light: #EBF3FC;
      --gold: #FFC107;
      --gold-dark: #e6a800;
      --gold-light: #FFF8E1;
      --green: #10b981;
      --green-light: #ECFDF5;
      --red: #ef4444;
      --red-light: #FEF2F2;
      --orange: #f97316;
      --slate-50: #F8FAFC;
      --slate-100: #F1F5F9;
      --slate-200: #E2E8F0;
      --slate-400: #94A3B8;
      --slate-500: #64748B;
      --slate-700: #334155;
      --slate-800: #1E293B;
      --white: #ffffff;
      --auto: color: auto;
      --auto-label: #AUTOMATED;
      --manual-label: #MANUAL-SETEISHA;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--slate-50);
      color: var(--slate-700);
      font-size: 1rem;
      line-height: 1.75;
    }

    /* ── LAYOUT ── */
    .page-wrap { max-width: 900px; margin: 0 auto; padding: 0 24px 80px; }

    /* ── HEADER ── */
    .page-header {
      background: linear-gradient(135deg, var(--navy) 0%, var(--blue-dark) 60%, var(--blue) 100%);
      padding: 60px 40px 50px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .page-header::before {
      content: '';
      position: absolute;
      top: -60px; right: -60px;
      width: 300px; height: 300px;
      border-radius: 50%;
      background: rgba(255,193,7,0.07);
      pointer-events: none;
    }
    .header-logo {
      display: inline-block;
      margin-bottom: 20px;
    }
    .header-logo img { height: 44px; filter: brightness(0) invert(1); opacity: 0.9; }
    .header-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--gold); color: #000;
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.1em;
      padding: 5px 16px; border-radius: 50px;
      margin-bottom: 18px;
    }
    .page-header h1 {
      font-family: 'Lora', serif;
      font-size: clamp(1.7rem, 3.5vw, 2.4rem);
      font-weight: 700;
      color: #fff;
      line-height: 1.2;
      margin-bottom: 14px;
    }
    .page-header p {
      color: rgba(255,255,255,0.72);
      font-size: 1.05rem;
      max-width: 560px;
      margin: 0 auto 28px;
    }
    .header-meta {
      display: flex; gap: 24px; justify-content: center; flex-wrap: wrap;
    }
    .header-meta-item {
      display: flex; align-items: center; gap: 8px;
      color: rgba(255,255,255,0.6);
      font-size: 0.85rem; font-weight: 500;
    }
    .header-meta-item i { color: var(--gold); font-size: 0.9rem; }

    /* ── COLOR KEY ── */
    .color-key {
      display: flex; gap: 12px; flex-wrap: wrap;
      background: var(--white);
      border: 1px solid var(--slate-200);
      border-radius: 12px;
      padding: 16px 20px;
      margin: 28px 0 0;
    }
    .color-key-title { font-size: 0.8rem; font-weight: 600; color: var(--slate-500); text-transform: uppercase; letter-spacing: 0.06em; width: 100%; margin-bottom: 2px; }
    .ck-pill {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 5px 14px; border-radius: 50px;
      font-size: 0.82rem; font-weight: 600;
    }
    .ck-auto { background: #EBF4FF; color: #1B4965; }
    .ck-manual { background: #FFF3E0; color: #92640a; }
    .ck-system { background: #F0FDF4; color: #166534; }

    /* ── SECTION TITLES ── */
    .section-block { margin-top: 52px; }
    .section-title {
      font-family: 'Lora', serif;
      font-size: 1.45rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 6px;
      display: flex; align-items: center; gap: 12px;
    }
    .section-title-icon {
      width: 36px; height: 36px;
      background: var(--blue-light);
      border-radius: 10px;
      display: inline-flex; align-items: center; justify-content: center;
      color: var(--blue);
      font-size: 1rem;
      flex-shrink: 0;
    }
    .section-sub { color: var(--slate-500); font-size: 0.95rem; margin-bottom: 20px; padding-left: 48px; }

    /* ── OVERVIEW CARDS ── */
    .overview-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 14px;
      margin-top: 20px;
    }
    .ov-card {
      background: var(--white);
      border: 1px solid var(--slate-200);
      border-radius: 14px;
      padding: 20px;
      position: relative;
    }
    .ov-card-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--slate-400); margin-bottom: 8px; }
    .ov-card-value { font-size: 1.05rem; font-weight: 600; color: var(--navy); line-height: 1.4; }
    .ov-card-icon {
      position: absolute; top: 18px; right: 18px;
      width: 32px; height: 32px;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.9rem;
    }
    .ov-card-icon.blue { background: var(--blue-light); color: var(--blue); }
    .ov-card-icon.gold { background: var(--gold-light); color: var(--gold-dark); }
    .ov-card-icon.green { background: var(--green-light); color: var(--green); }
    .ov-card-icon.red  { background: var(--red-light); color: var(--red); }

    /* ── PIPELINE STAGES ── */
    .pipeline-wrap { margin-top: 20px; }
    .pipeline-stage {
      display: flex;
      align-items: center;
      gap: 0;
      margin-bottom: 4px;
    }
    .stage-num {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: var(--navy);
      color: #fff;
      font-size: 0.78rem;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      z-index: 2;
    }
    .stage-connector {
      width: 20px; height: 2px;
      background: var(--slate-200);
      flex-shrink: 0;
    }
    .stage-box {
      flex: 1;
      background: var(--white);
      border: 1px solid var(--slate-200);
      border-radius: 10px;
      padding: 10px 16px;
      font-size: 0.92rem;
      font-weight: 500;
      color: var(--slate-800);
      display: flex; align-items: center; justify-content: space-between;
    }
    .stage-box.highlight { border-color: var(--blue); background: var(--blue-light); color: var(--blue-dark); }
    .stage-box.won { border-color: var(--green); background: var(--green-light); color: #065f46; }
    .stage-box.lost { border-color: var(--red); background: var(--red-light); color: #991b1b; }
    .stage-box.nurture { border-color: var(--gold-dark); background: var(--gold-light); color: #7a5200; }
    .stage-tag {
      font-size: 0.72rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.06em;
      padding: 3px 10px; border-radius: 50px;
    }
    .tag-auto { background: #DBEAFE; color: #1e40af; }
    .tag-manual { background: #FEF3C7; color: #92400e; }
    .stage-line {
      width: 2px;
      height: 8px;
      background: var(--slate-200);
      margin-left: 15px;
    }

    /* ── WORKFLOW TABLE ── */
    .workflow-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 16px;
      font-size: 0.9rem;
    }
    .workflow-table th {
      background: var(--navy);
      color: #fff;
      padding: 10px 16px;
      text-align: left;
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .workflow-table th:first-child { border-radius: 10px 0 0 0; }
    .workflow-table th:last-child  { border-radius: 0 10px 0 0; }
    .workflow-table td {
      padding: 11px 16px;
      border-bottom: 1px solid var(--slate-200);
      vertical-align: top;
      color: var(--slate-700);
    }
    .workflow-table tr:last-child td { border-bottom: none; }
    .workflow-table tr:nth-child(even) td { background: var(--slate-50); }
    .workflow-table tr:nth-child(odd) td { background: var(--white); }
    .step-num-badge {
      display: inline-flex; align-items: center; justify-content: center;
      width: 24px; height: 24px;
      border-radius: 50%;
      background: var(--navy);
      color: #fff;
      font-size: 0.72rem;
      font-weight: 700;
    }
    .pill-auto   { display: inline-flex; align-items: center; gap: 5px; background: #EBF4FF; color: #1B4965; padding: 3px 11px; border-radius: 50px; font-size: 0.78rem; font-weight: 600; }
    .pill-manual { display: inline-flex; align-items: center; gap: 5px; background: #FFF3E0; color: #92640a; padding: 3px 11px; border-radius: 50px; font-size: 0.78rem; font-weight: 600; }
    .pill-system { display: inline-flex; align-items: center; gap: 5px; background: #F0FDF4; color: #166534; padding: 3px 11px; border-radius: 50px; font-size: 0.78rem; font-weight: 600; }

    /* ── EMAIL SEQUENCE ── */
    .email-sequence { margin-top: 20px; display: flex; flex-direction: column; gap: 14px; }
    .email-card {
      background: var(--white);
      border: 1px solid var(--slate-200);
      border-radius: 14px;
      padding: 20px 22px;
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: 16px;
      align-items: start;
    }
    .email-timing {
      text-align: center;
      background: var(--navy);
      color: #fff;
      border-radius: 10px;
      padding: 12px 8px;
      font-size: 0.78rem;
      font-weight: 600;
      line-height: 1.3;
    }
    .email-timing .big { font-size: 1.5rem; font-weight: 700; display: block; line-height: 1; margin-bottom: 2px; }
    .email-timing.gold-bg { background: var(--gold-dark); color: #000; }
    .email-meta-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--slate-400); margin-bottom: 4px; }
    .email-subject { font-size: 1rem; font-weight: 600; color: var(--navy); margin-bottom: 6px; }
    .email-angle { font-size: 0.9rem; color: var(--slate-500); }
    .email-cta {
      display: inline-flex; align-items: center; gap: 6px;
      margin-top: 10px;
      background: var(--blue-light);
      color: var(--blue-dark);
      border-radius: 50px;
      padding: 4px 14px;
      font-size: 0.8rem;
      font-weight: 600;
    }

    /* ── FORM FIELDS ── */
    .form-fields-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 12px;
      margin-top: 16px;
    }
    .form-field-card {
      background: var(--white);
      border: 1px solid var(--slate-200);
      border-radius: 12px;
      padding: 16px 18px;
    }
    .form-field-name { font-weight: 600; color: var(--navy); font-size: 0.95rem; margin-bottom: 4px; }
    .form-field-type { font-size: 0.78rem; color: var(--slate-400); font-family: 'DM Mono', monospace; }
    .form-field-note { font-size: 0.85rem; color: var(--slate-500); margin-top: 6px; }
    .form-field-req {
      display: inline-block;
      background: var(--red-light);
      color: var(--red);
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      padding: 2px 8px;
      border-radius: 50px;
      margin-left: 8px;
    }

    /* ── PENDING QUESTIONS ── */
    .questions-block { margin-top: 20px; display: flex; flex-direction: column; gap: 12px; }
    .question-card {
      background: var(--white);
      border: 1px solid var(--slate-200);
      border-left: 4px solid var(--gold);
      border-radius: 0 12px 12px 0;
      padding: 18px 20px;
    }
    .question-card.answered {
      border-left-color: var(--green);
      background: var(--green-light);
    }
    .q-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .q-num {
      width: 26px; height: 26px;
      border-radius: 50%;
      background: var(--gold);
      color: #000;
      font-size: 0.75rem;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .q-num.answered { background: var(--green); color: #fff; }
    .q-status-badge {
      font-size: 0.72rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.06em;
      padding: 3px 10px; border-radius: 50px;
    }
    .q-status-pending  { background: var(--gold-light); color: #7a5200; }
    .q-status-answered { background: var(--green-light); color: #065f46; }
    .q-status-partial  { background: #FFF3E0; color: #92400e; }
    .q-directed-to { font-size: 0.78rem; color: var(--slate-400); margin-left: auto; }
    .question-text { font-weight: 600; color: var(--navy); font-size: 0.95rem; margin-bottom: 6px; }
    .question-context { font-size: 0.88rem; color: var(--slate-500); line-height: 1.6; }
    .answer-box {
      margin-top: 10px;
      background: rgba(16,185,129,0.08);
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 0.88rem;
      color: #065f46;
      display: flex; gap: 8px; align-items: flex-start;
    }
    .answer-box i { margin-top: 2px; flex-shrink: 0; }

    /* ── CHECKLIST ── */
    .build-checklist { margin-top: 16px; display: flex; flex-direction: column; gap: 8px; }
    .checklist-item {
      display: flex; align-items: center; gap: 14px;
      background: var(--white);
      border: 1px solid var(--slate-200);
      border-radius: 10px;
      padding: 13px 18px;
    }
    .checklist-item.done { background: var(--green-light); border-color: rgba(16,185,129,0.3); }
    .checklist-item.in-progress { background: var(--gold-light); border-color: rgba(255,193,7,0.4); }
    .check-box {
      width: 22px; height: 22px;
      border-radius: 6px;
      border: 2px solid var(--slate-300);
      flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
    }
    .check-box.done { background: var(--green); border-color: var(--green); color: #fff; font-size: 0.75rem; }
    .check-box.pending { border-color: var(--slate-300); }
    .check-label { font-weight: 500; color: var(--slate-700); font-size: 0.92rem; flex: 1; }
    .checklist-item.done .check-label { color: #065f46; }
    .check-phase {
      font-size: 0.72rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.05em;
      padding: 3px 10px; border-radius: 50px;
      background: var(--slate-100); color: var(--slate-500);
    }

    /* ── INFO BOX ── */
    .info-box {
      background: var(--blue-light);
      border: 1px solid rgba(42,100,167,0.2);
      border-left: 4px solid var(--blue);
      border-radius: 0 12px 12px 0;
      padding: 16px 20px;
      margin-top: 16px;
      font-size: 0.92rem;
      color: var(--blue-dark);
      display: flex; gap: 12px; align-items: flex-start;
    }
    .info-box i { margin-top: 2px; flex-shrink: 0; }

    .warn-box {
      background: var(--gold-light);
      border: 1px solid rgba(255,193,7,0.3);
      border-left: 4px solid var(--gold-dark);
      border-radius: 0 12px 12px 0;
      padding: 16px 20px;
      margin-top: 16px;
      font-size: 0.92rem;
      color: #7a5200;
      display: flex; gap: 12px; align-items: flex-start;
    }
    .warn-box i { margin-top: 2px; flex-shrink: 0; }

    /* ── FOOTER ── */
    .page-footer {
      margin-top: 60px;
      padding: 28px;
      background: var(--navy);
      border-radius: 16px;
      text-align: center;
      color: rgba(255,255,255,0.6);
      font-size: 0.85rem;
    }
    .page-footer strong { color: #fff; }
    .page-footer a { color: var(--gold); text-decoration: none; }

    /* ── DIVIDER ── */
    .divider { height: 1px; background: var(--slate-200); margin: 40px 0; }

    @media(max-width: 640px) {
      .page-header { padding: 40px 20px 36px; }
      .email-card { grid-template-columns: 1fr; }
      .workflow-table { font-size: 0.82rem; }
      .workflow-table td, .workflow-table th { padding: 8px 10px; }
    }
  </style>
</head>
<body>

  <!-- ══ HEADER ══ -->
  <header class="page-header">
    <div class="header-logo">
      <img src="https://assets.cdn.filesafe.space/UDKdmJIdT4xB1V6Lye64/media/68f7cb4d3a4642fd12cdeaab.png" alt="Hearing Benefit Services" />
    </div>
    <div class="header-badge"><i class="fas fa-robot" style="margin-right:6px;"></i> Staff Training Guide</div>
    <h1>Hearing Test Lead Automation</h1>
    <p>How every hearing test submission flows from the website into our sales pipeline and what happens next.</p>
    <div class="header-meta">
      <div class="header-meta-item"><i class="fas fa-calendar-alt"></i> June 2026</div>
      <div class="header-meta-item"><i class="fas fa-code-branch"></i> Version 1.0</div>
      <div class="header-meta-item"><i class="fas fa-user"></i> Rhett &amp; Seteisha</div>
    </div>
  </header>

  <div class="page-wrap">

    <!-- COLOR KEY -->
    <div class="color-key">
      <div class="color-key-title">Color Key</div>
      <span class="ck-pill ck-auto"><i class="fas fa-robot"></i> AUTOMATED — GHL handles this automatically</span>
      <span class="ck-pill ck-manual"><i class="fas fa-user"></i> MANUAL — SETEISHA action required</span>
      <span class="ck-pill ck-system"><i class="fas fa-cog"></i> SYSTEM — One-time setup by Rhett</span>
    </div>

    <!-- ══ OVERVIEW ══ -->
    <div class="section-block">
      <div class="section-title">
        <span class="section-title-icon"><i class="fas fa-map-signs"></i></span>
        Campaign Overview
      </div>
      <div class="section-sub">What this automation does at a glance.</div>
      <div class="overview-grid">
        <div class="ov-card">
          <div class="ov-card-label">Trigger</div>
          <div class="ov-card-value">Hearing test form submitted on website</div>
          <div class="ov-card-icon blue"><i class="fas fa-bolt"></i></div>
        </div>
        <div class="ov-card">
          <div class="ov-card-label">Pipeline</div>
          <div class="ov-card-value">Hearing Test Leads (12 stages)</div>
          <div class="ov-card-icon blue"><i class="fas fa-filter"></i></div>
        </div>
        <div class="ov-card">
          <div class="ov-card-label">Follow-Up Emails</div>
          <div class="ov-card-value">4 emails: Day 0, Day 3, Day 7, Day 14</div>
          <div class="ov-card-icon gold"><i class="fas fa-envelope"></i></div>
        </div>
        <div class="ov-card">
          <div class="ov-card-label">Tag Applied</div>
          <div class="ov-card-value"><code style="font-family:'DM Mono',monospace;font-size:0.9em;">hearing_test_lead</code></div>
          <div class="ov-card-icon green"><i class="fas fa-tag"></i></div>
        </div>
        <div class="ov-card">
          <div class="ov-card-label">Seteisha Notified?</div>
          <div class="ov-card-value">Yes — task created on any reply</div>
          <div class="ov-card-icon gold"><i class="fas fa-bell"></i></div>
        </div>
        <div class="ov-card">
          <div class="ov-card-label">Goal</div>
          <div class="ov-card-value">Book a free consult → close a hearing aid sale</div>
          <div class="ov-card-icon green"><i class="fas fa-bullseye"></i></div>
        </div>
      </div>
    </div>

    <!-- ══ HOW IT WORKS ══ -->
    <div class="section-block">
      <div class="section-title">
        <span class="section-title-icon"><i class="fas fa-route"></i></span>
        How It Works — Step by Step
      </div>
      <div class="section-sub">The full journey from website visitor to booked consult.</div>

      <table class="workflow-table">
        <thead>
          <tr>
            <th style="width:44px;">#</th>
            <th>What Happens</th>
            <th>Who / What</th>
            <th>Type</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="step-num-badge">1</span></td>
            <td><strong>Visitor takes hearing test</strong> on hearingbenefitservices.com/hearingtest. Results show instantly on screen.</td>
            <td>Website visitor</td>
            <td><span class="pill-auto"><i class="fas fa-globe"></i> Website</span></td>
          </tr>
          <tr>
            <td><span class="step-num-badge">2</span></td>
            <td><strong>Form appears below results.</strong> Visitor enters name + email + phone to receive results by email.</td>
            <td>GHL Form (embedded on page)</td>
            <td><span class="pill-auto"><i class="fas fa-robot"></i> Automated</span></td>
          </tr>
          <tr>
            <td><span class="step-num-badge">3</span></td>
