    <li><a href="#audience">Audience</a></li>
    <li><a href="#campaigns">Ad Campaigns</a></li>
    <li><a href="#creative">Ad Creative</a></li>
    <li><a href="#workflow">GHL Workflow</a></li>
    <li><a href="#lead-workflows">Lead Workflows</a></li>
    <li><a href="#budget">Budget & KPIs</a></li>
    <li><a href="#checklist">Launch Checklist</a></li>
  </ul>
</nav>

