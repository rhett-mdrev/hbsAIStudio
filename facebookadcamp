<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HBS Facebook & Instagram Ad Campaign — Team Brief</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;1,9..144,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #0d1f3c;
    --navy-mid: #152d57;
    --blue: #1a5faa;
    --blue-light: #2d7dd2;
    --teal: #00b4a6;
    --teal-light: #00d4c4;
    --gold: #f0a500;
    --gold-light: #ffc23a;
    --cream: #faf8f3;
    --white: #ffffff;
    --text-dark: #0d1f3c;
    --text-mid: #3a4a62;
    --text-light: #7a8ba0;
    --border: #e2e8f0;
    --card-bg: #ffffff;
    --section-alt: #f4f7fb;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text-dark); line-height: 1.7; font-size: 16px; }

  nav {
    position: fixed; top: 0; left: 0; right: 0;
    background: rgba(13, 31, 60, 0.97);
    backdrop-filter: blur(12px);
    z-index: 100; padding: 0 40px;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px; border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .nav-logo { font-family: 'Fraunces', serif; font-weight: 700; font-size: 18px; color: var(--white); letter-spacing: -0.3px; }
  .nav-logo span { color: var(--teal); }
  .nav-links { display: flex; gap: 28px; list-style: none; }
  .nav-links a { color: rgba(255,255,255,0.65); text-decoration: none; font-size: 13px; font-weight: 500; letter-spacing: 0.3px; transition: color 0.2s; }
  .nav-links a:hover { color: var(--teal-light); }

  .hero {
    background: var(--navy); min-height: 100vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 120px 40px 80px;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(0,180,166,0.15) 0%, transparent 60%), radial-gradient(ellipse 50% 50% at 80% 80%, rgba(26,95,170,0.2) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero h1 { font-family: 'Fraunces', serif; font-size: clamp(42px, 6vw, 72px); font-weight: 700; color: var(--white); line-height: 1.1; letter-spacing: -1.5px; max-width: 820px; margin-bottom: 24px; opacity: 0; animation: fadeUp 0.6s ease forwards 0.35s; }
  .hero h1 em { font-style: italic; color: var(--teal-light); }
  .hero-sub { font-size: 18px; color: rgba(255,255,255,0.65); max-width: 560px; font-weight: 300; margin-bottom: 48px; opacity: 0; animation: fadeUp 0.6s ease forwards 0.5s; }
  .hero-stats { display: flex; gap: 48px; opacity: 0; animation: fadeUp 0.6s ease forwards 0.65s; }
  .hero-stat { text-align: center; }
  .hero-stat-num { font-family: 'Fraunces', serif; font-size: 38px; font-weight: 600; color: var(--gold-light); line-height: 1; display: block; }
  .hero-stat-label { font-size: 12px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.8px; margin-top: 6px; }
  .hero-divider { width: 1px; height: 48px; background: rgba(255,255,255,0.15); margin-top: 8px; }

  section { padding: 96px 40px; max-width: 1100px; margin: 0 auto; }
  section.alt-bg { max-width: 100%; background: var(--section-alt); padding: 96px 40px; }
  section.alt-bg > .inner { max-width: 1100px; margin: 0 auto; }

  .section-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--blue); margin-bottom: 12px; display: flex; align-items: center; gap: 10px; }
  .section-eyebrow::before { content: ''; width: 28px; height: 2px; background: var(--teal); display: inline-block; }

  h2 { font-family: 'Fraunces', serif; font-size: clamp(30px, 4vw, 44px); font-weight: 700; letter-spacing: -1px; color: var(--text-dark); line-height: 1.15; margin-bottom: 16px; }
  .section-intro { font-size: 17px; color: var(--text-mid); max-width: 640px; margin-bottom: 56px; font-weight: 300; }

  .goal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .goal-card { background: var(--white); border-radius: 16px; padding: 36px; border: 1px solid var(--border); position: relative; overflow: hidden; }
  .goal-card::after { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: linear-gradient(to bottom, var(--teal), var(--blue-light)); border-radius: 4px 0 0 4px; }
  .goal-card.gold::after { background: linear-gradient(to bottom, var(--gold), var(--gold-light)); }
  .goal-card-icon { width: 44px; height: 44px; background: linear-gradient(135deg, var(--teal), var(--blue)); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; font-size: 20px; }
  .goal-card.gold .goal-card-icon { background: linear-gradient(135deg, var(--gold), #f07000); }
  .goal-card h3 { font-family: 'Fraunces', serif; font-size: 20px; font-weight: 600; margin-bottom: 10px; color: var(--text-dark); }
  .goal-card p { font-size: 15px; color: var(--text-mid); line-height: 1.65; }

  .flow-wrap { background: var(--navy); border-radius: 20px; padding: 48px; margin-top: 40px; }
  .flow-title { font-family: 'Fraunces', serif; font-size: 22px; color: var(--white); margin-bottom: 40px; text-align: center; }
  .flow-steps { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 0; }
  .flow-step { display: flex; flex-direction: column; align-items: center; text-align: center; flex: 1; min-width: 100px; }
  .flow-step-circle { width: 52px; height: 52px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; margin-bottom: 12px; flex-shrink: 0; }
  .flow-step-circle.teal { background: rgba(0,180,166,0.2); border: 2px solid var(--teal); }
  .flow-step-circle.blue { background: rgba(45,125,210,0.2); border: 2px solid var(--blue-light); }
  .flow-step-circle.gold { background: rgba(240,165,0,0.2); border: 2px solid var(--gold); }
  .flow-step-label { font-size: 12px; color: rgba(255,255,255,0.75); font-weight: 500; line-height: 1.4; max-width: 90px; }
  .flow-arrow { color: rgba(255,255,255,0.25); font-size: 18px; flex-shrink: 0; margin: 0 4px; padding-bottom: 28px; }

  .audience-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
  .audience-box { background: var(--white); border-radius: 16px; padding: 36px; border: 1px solid var(--border); }
  .audience-box h3 { font-family: 'Fraunces', serif; font-size: 20px; font-weight: 600; margin-bottom: 20px; color: var(--text-dark); display: flex; align-items: center; gap: 10px; }
  .badge { font-family: 'DM Sans', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 3px 10px; border-radius: 100px; }
  .badge.primary { background: rgba(0,180,166,0.12); color: var(--teal); border: 1px solid rgba(0,180,166,0.3); }
  .badge.retarget { background: rgba(240,165,0,0.1); color: var(--gold); border: 1px solid rgba(240,165,0,0.3); }
  .audience-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .audience-list li { font-size: 15px; color: var(--text-mid); display: flex; align-items: flex-start; gap: 10px; line-height: 1.5; }
  .audience-list li::before { content: '✓'; color: var(--teal); font-weight: 700; flex-shrink: 0; margin-top: 1px; }

  .campaigns-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-bottom: 48px; }
  .campaign-card { background: var(--white); border-radius: 16px; padding: 32px; border: 1px solid var(--border); transition: transform 0.2s, box-shadow 0.2s; }
  .campaign-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(13,31,60,0.1); }
  .campaign-num { font-family: 'Fraunces', serif; font-size: 48px; font-weight: 700; line-height: 1; color: var(--border); margin-bottom: 16px; }
  .campaign-tag { display: inline-block; font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 4px 12px; border-radius: 100px; margin-bottom: 16px; }
  .campaign-tag.tofu { background: rgba(0,180,166,0.1); color: var(--teal); border: 1px solid rgba(0,180,166,0.25); }
  .campaign-tag.mofu { background: rgba(26,95,170,0.1); color: var(--blue); border: 1px solid rgba(26,95,170,0.25); }
  .campaign-tag.promo { background: rgba(240,165,0,0.1); color: var(--gold); border: 1px solid rgba(240,165,0,0.3); }
  .campaign-card h3 { font-family: 'Fraunces', serif; font-size: 20px; font-weight: 600; margin-bottom: 10px; line-height: 1.3; }
  .campaign-card p { font-size: 14px; color: var(--text-mid); margin-bottom: 20px; line-height: 1.6; }
  .campaign-cta-label { font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--text-light); margin-bottom: 6px; }
  .campaign-cta-val { font-size: 14px; font-weight: 600; color: var(--blue); }

  .ad-copy-section { margin-top: 48px; }
  .ad-copy-section h3 { font-family: 'Fraunces', serif; font-size: 26px; font-weight: 600; margin-bottom: 24px; color: var(--text-dark); }
  .accordion { display: flex; flex-direction: column; gap: 12px; }
  .accordion-item { background: var(--white); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
  .accordion-header { padding: 20px 24px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; transition: background 0.2s; user-select: none; }
  .accordion-header:hover { background: var(--section-alt); }
  .accordion-header-left { display: flex; align-items: center; gap: 14px; }
  .accordion-label { font-size: 15px; font-weight: 600; color: var(--text-dark); }
  .accordion-sublabel { font-size: 13px; color: var(--text-light); }
  .accordion-toggle { width: 28px; height: 28px; border-radius: 50%; background: var(--section-alt); display: flex; align-items: center; justify-content: center; font-size: 16px; color: var(--text-mid); transition: transform 0.25s, background 0.2s; flex-shrink: 0; }
  .accordion-item.open .accordion-toggle { transform: rotate(45deg); background: var(--teal); color: white; }
  .accordion-body { max-height: 0; overflow: hidden; transition: max-height 0.35s ease; }
  .accordion-item.open .accordion-body { max-height: 600px; }
  .accordion-content { padding: 0 24px 24px; border-top: 1px solid var(--border); padding-top: 20px; }
  .ad-mock { background: #f0f2f5; border-radius: 12px; padding: 20px; font-size: 14px; color: var(--text-dark); }
  .ad-mock-headline { font-weight: 700; font-size: 16px; margin-bottom: 8px; color: var(--navy); }
  .ad-mock-body { color: #444; line-height: 1.65; margin-bottom: 14px; }
  .ad-mock-cta { display: inline-block; background: var(--blue); color: white; padding: 8px 18px; border-radius: 6px; font-weight: 600; font-size: 13px; }

  .pipeline-wrap { display: flex; gap: 8px; flex-wrap: wrap; }
  .pipeline-stage { display: flex; flex-direction: column; align-items: center; gap: 8px; flex: 1; min-width: 72px; }
  .stage-dot { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; color: white; flex-shrink: 0; }
  .stage-dot.active { background: var(--teal); }
  .stage-dot.mid { background: var(--blue); }
  .stage-dot.won { background: #16a34a; }
  .stage-dot.lost { background: #dc2626; }
  .stage-dot.nurture { background: var(--gold); }
  .stage-name { font-size: 11px; color: var(--text-mid); text-align: center; line-height: 1.35; font-weight: 500; }
  .pipeline-connector { width: 20px; height: 2px; background: var(--border); margin-top: 19px; flex-shrink: 0; }

  .workflow-steps { display: flex; flex-direction: column; gap: 0; position: relative; }
  .workflow-steps::before { content: ''; position: absolute; left: 19px; top: 20px; bottom: 20px; width: 2px; background: linear-gradient(to bottom, var(--teal), var(--blue-light)); }
  .workflow-step { display: flex; align-items: flex-start; gap: 20px; padding: 12px 0; position: relative; }
  .workflow-step-dot { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; position: relative; z-index: 1; }
  .workflow-step-dot.sms { background: rgba(0,180,166,0.15); border: 2px solid var(--teal); }
  .workflow-step-dot.email { background: rgba(26,95,170,0.15); border: 2px solid var(--blue); }
  .workflow-step-dot.wait { background: rgba(240,165,0,0.15); border: 2px solid var(--gold); }
  .workflow-step-dot.task { background: rgba(168,85,247,0.15); border: 2px solid #a855f7; }
  .workflow-step-dot.tag { background: rgba(22,163,74,0.15); border: 2px solid #16a34a; }
  .workflow-step-dot.branch { background: rgba(239,68,68,0.15); border: 2px solid #ef4444; }
  .workflow-step-dot.ai { background: rgba(0,180,166,0.15); border: 2px solid var(--teal-light); }
  .workflow-step-content { padding-top: 8px; flex: 1; }
  .workflow-step-title { font-weight: 600; font-size: 15px; color: var(--text-dark); margin-bottom: 4px; }
  .workflow-step-detail { font-size: 13px; color: var(--text-mid); line-height: 1.55; }
  .workflow-step-detail .msg-preview { background: var(--section-alt); border-left: 3px solid var(--teal); padding: 10px 14px; border-radius: 0 8px 8px 0; margin-top: 8px; font-style: italic; font-size: 13px; color: var(--text-mid); }

  .budget-table { width: 100%; border-collapse: collapse; border-radius: 12px; overflow: hidden; border: 1px solid var(--border); }
  .budget-table th { background: var(--navy); color: white; padding: 16px 20px; text-align: left; font-size: 12px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; }
  .budget-table td { padding: 16px 20px; font-size: 15px; border-bottom: 1px solid var(--border); color: var(--text-mid); }
  .budget-table tr:last-child td { border-bottom: none; }
  .budget-table tr:nth-child(even) td { background: var(--section-alt); }
  .budget-table td strong { color: var(--text-dark); font-weight: 600; }
  .budget-table td.highlight { color: var(--teal); font-weight: 700; }

  .kpi-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; }
  .kpi-card { background: var(--white); border-radius: 14px; padding: 24px 20px; border: 1px solid var(--border); text-align: center; }
  .kpi-val { font-family: 'Fraunces', serif; font-size: 26px; font-weight: 700; color: var(--navy); line-height: 1; margin-bottom: 6px; }
  .kpi-label { font-size: 12px; color: var(--text-light); font-weight: 500; line-height: 1.4; }
  .kpi-card.accent .kpi-val { color: var(--teal); }
  .kpi-card.gold .kpi-val { color: var(--gold); }
  .kpi-card.green .kpi-val { color: #16a34a; }

  .checklist-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
  .checklist-box { background: var(--white); border-radius: 16px; padding: 32px; border: 1px solid var(--border); }
  .checklist-box h3 { font-family: 'Fraunces', serif; font-size: 18px; font-weight: 600; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
  .checklist-items { display: flex; flex-direction: column; gap: 10px; }
  .checklist-item { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: var(--text-mid); line-height: 1.5; }
  .check-box { width: 18px; height: 18px; border: 2px solid var(--border); border-radius: 4px; flex-shrink: 0; margin-top: 1px; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; font-size: 11px; color: transparent; }
  .check-box.checked { background: var(--teal); border-color: var(--teal); color: white; }

  .roles-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .role-card { background: var(--navy); border-radius: 16px; padding: 32px; color: white; position: relative; overflow: hidden; }
  .role-avatar { width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Fraunces', serif; font-size: 20px; font-weight: 700; margin-bottom: 16px; }
  .role-card.rhett .role-avatar { background: rgba(0,180,166,0.2); color: var(--teal-light); border: 2px solid rgba(0,180,166,0.3); }
  .role-card.set .role-avatar { background: rgba(240,165,0,0.2); color: var(--gold-light); border: 2px solid rgba(240,165,0,0.3); }
  .role-name { font-family: 'Fraunces', serif; font-size: 22px; font-weight: 600; margin-bottom: 4px; }
  .role-title { font-size: 12px; color: rgba(255,255,255,0.45); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 20px; }
  .role-tasks { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .role-tasks li { font-size: 13px; color: rgba(255,255,255,0.7); display: flex; align-items: flex-start; gap: 8px; line-height: 1.5; }
  .role-tasks li::before { content: '→'; flex-shrink: 0; color: rgba(255,255,255,0.3); }

  footer { background: var(--navy); color: rgba(255,255,255,0.5); text-align: center; padding: 40px; font-size: 13px; }
  footer strong { color: var(--teal-light); }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.55s ease, transform 0.55s ease; }
  .reveal.visible { opacity: 1; transform: none; }
  .section-divider { height: 1px; background: var(--border); max-width: 1100px; margin: 0 auto; }

  /* NEW WORKFLOW CARDS */
  .wf-card { background: var(--white); border-radius: 20px; border: 1px solid var(--border); overflow: hidden; margin-bottom: 40px; }
  .wf-card-header { padding: 28px 36px; display: flex; align-items: center; gap: 20px; border-bottom: 1px solid var(--border); }
  .wf-card-header.messenger { background: linear-gradient(135deg, #0d1f3c 0%, #152d57 100%); }
  .wf-card-header.lead-ad { background: linear-gradient(135deg, #1a5faa 0%, #0d3a7a 100%); }
  .wf-card-icon { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0; }
  .wf-card-header.messenger .wf-card-icon { background: rgba(0,212,196,0.15); border: 2px solid rgba(0,212,196,0.4); }
  .wf-card-header.lead-ad .wf-card-icon { background: rgba(255,194,58,0.15); border: 2px solid rgba(255,194,58,0.4); }
  .wf-card-title { font-family: 'Fraunces', serif; font-size: 22px; font-weight: 700; color: white; margin-bottom: 4px; }
  .wf-card-subtitle { font-size: 13px; color: rgba(255,255,255,0.55); }
  .wf-trigger-badge { margin-left: auto; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; padding: 8px 16px; text-align: right; flex-shrink: 0; }
  .wf-trigger-label { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 4px; }
  .wf-trigger-val { font-size: 13px; font-weight: 600; color: var(--teal-light); }
  .wf-card-body { padding: 36px; }
  .wf-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
  .wf-col-label { font-weight: 700; font-size: 12px; letter-spacing: 1px; text-transform: uppercase; color: var(--text-light); margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid var(--border); }
  .wf-difference-box { background: var(--navy); border-radius: 14px; padding: 24px 28px; margin-top: 32px; }
  .wf-difference-title { font-family: 'Fraunces', serif; font-size: 16px; color: white; margin-bottom: 16px; }
  .wf-diff-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
  .wf-diff-item { }
  .wf-diff-label { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-bottom: 6px; }
  .wf-diff-val { font-size: 13px; color: rgba(255,255,255,0.8); line-height: 1.5; }
  .wf-diff-val.teal { color: var(--teal-light); font-weight: 600; }
  .wf-diff-val.gold { color: var(--gold-light); font-weight: 600; }

  @media (max-width: 768px) {
    nav { padding: 0 20px; }
    .nav-links { display: none; }
    section { padding: 64px 20px; }
    .hero { padding: 100px 20px 60px; }
    .hero-stats { gap: 28px; }
    .hero-stat-num { font-size: 28px; }
    .goal-grid, .audience-grid, .checklist-grid { grid-template-columns: 1fr; }
    .campaigns-grid { grid-template-columns: 1fr; }
    .kpi-grid { grid-template-columns: repeat(2, 1fr); }
    .roles-grid { grid-template-columns: 1fr; }
    .wf-two-col { grid-template-columns: 1fr; gap: 32px; }
    .wf-diff-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<nav>
  <div class="nav-logo">Hearing Benefit <span>Services</span></div>
  <ul class="nav-links">
